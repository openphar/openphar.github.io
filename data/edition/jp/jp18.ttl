supplement:jp18-supplement2
    a bib:Supplement ;
    skos:prefLabel "Japanese Pharmacopoeia 18th Edition Supplement 2"@en ;
    skos:prefLabel "第十八改正日本薬局方 第二追補"@ja ;

    bib:supplementNumber "2" ;
    bib:supplementTo edition:jp/jp18 ;

    bib:supplementPublicationDate "2023-12-25"^^xsd:date ;
    bib:supplementEffectiveDate "2024-06-28"^^xsd:date .

