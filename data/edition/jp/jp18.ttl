    a bib:Supplement ;
    skos:prefLabel "Japanese Pharmacopoeia 18th Edition Supplement 1"@en ;
    skos:prefLabel "第十八改正日本薬局方 第一追補"@ja ;

    bib:supplementNumber "1" ;
    bib:supplementTo edition:jp/jp18 ;

    bib:supplementPublicationDate "2022-12-12"^^xsd:date ;
    bib:supplementEffectiveDate "2023-06-12"^^xsd:date .

# =============================================================================
