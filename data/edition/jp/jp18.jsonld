      "hasPublisher": { "@id": "op:JP" },
      "publicationDate": "2021-06-25",
      "effectiveDate": "2021-12-01",
      "monographCount": 327,
      "editionUrl": { "@id": "https://www.mhlw.go.jp/topics/bukyoku/iyaku/yakkyoku/index.html" },
      "officialLanguage": ["ja", "en"],
      "hasSupplement": [
        { "@id": "jp/jp18-supplement1" },
        { "@id": "jp/jp18-supplement2" }
      ],
      "description": {
        "en": "The Japanese Pharmacopoeia (JP) 18th Edition is the official pharmacopoeia of Japan, published by the Ministry of Health, Labour and Welfare (MHLW). It contains standards for pharmaceuticals, including chemical drugs, crude drugs, biological products, and formulations."
      }
    },
    {
