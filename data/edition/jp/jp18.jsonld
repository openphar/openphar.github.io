      "@type": "Supplement",
      "prefLabel": {
        "en": "Japanese Pharmacopoeia 18th Edition Supplement 2",
        "ja": "第十八改正日本薬局方 第二追補"
      },
      "supplementNumber": "2",
      "supplementTo": { "@id": "jp/jp18" },
      "supplementPublicationDate": "2023-12-25",
      "supplementEffectiveDate": "2024-06-28"
    },
    {
      "@id": "jp/jp19",
      "@type": "Edition",
      "prefLabel": {
