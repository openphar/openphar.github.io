{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",

  "@id": "https://www.openphar.org/data/monograph/hkcmms/radix-ginseng",
  "@type": "CrudeDrugMonograph",

  "prefLabel": {
    "en": "Radix Ginseng",
    "zh-Hant": "人參",
    "la": "Radix Ginseng"
  },

  "altLabel": [
    { "@value": "Ginseng", "@language": "en" },
    { "@value": "Ren Shen", "@language": "en" },
    { "@value": "人參", "@language": "zh-Hant" },
    { "@value": " Ginseng radix", "@language": "la" }
  ],

  "monographId": "HKCMMS-V2-001",
  "publisher": "HKCMMS",
  "status": "Official",
  "effectiveDate": "2022-01-01",
  "version": "2",

  "definition": {
    "en": "Radix Ginseng is the dried root of Panax ginseng C.A. Meyer (Araliaceae)."
  },
  "definition": {
    "zh-Hant": "人參為五加科植物人參的乾燥根。"
  },

  "referencesPreparation": {
    "@id": "https://www.herbapedia.org/entity/preparation/dried-ginseng-root"
  },

  "referencesTCMProfile": {
    "@id": "https://www.herbapedia.org/system/tcm/profile/ren-shen"
  },

  "botanicalSource": {
    "@type": "BotanicalSource",
    "referencesPlantSpecies": {
      "@id": "https://www.herbapedia.org/entity/botanical/species/panax-ginseng"
    },
    "plantPartUsed": {
      "en": "Root",
      "zh-Hant": "根"
    },
    "collectionPeriod": {
      "en": "Collected in autumn when the plants are 4-6 years old"
    }
  },

  "macroscopicDescription": {
    "@type": "MacroscopicDescription",
    "color": {
      "en": "Yellowish white to pale brown",
      "zh-Hant": "黃白色至淺棕色"
    },
    "shape": {
      "en": "Main root fusiform or cylindrical, often with lateral roots",
      "zh-Hant": "主根呈紡錘形或圓柱形，常有側根"
    },
    "size": {
      "en": "Main root 5-20 cm long, 0.5-3 cm in diameter",
      "zh-Hant": "主根長5-20厘米，直徑0.5-3厘米"
    },
    "texture": {
      "en": "Hard and brittle",
      "zh-Hant": "質硬而脆"
    },
    "fracture": {
      "en": "Fracture is flat, pale yellowish white",
      "zh-Hant": "斷面平坦，淡黃白色"
    },
    "odor": {
      "en": "Slightly aromatic",
      "zh-Hant": "微有香氣"
    },
    "taste": {
      "en": "Sweet, slightly bitter",
      "zh-Hant": "味甘、微苦"
    }
  },

  "microscopicDescription": {
    "@type": "MicroscopicDescription",
    "transverseSection": {
      "en": "Cork of several layers of cells; phloem with scattered secretory canals, phloem fibers, and parenchyma; xylem with vessels, tracheids, wood fibers, and rays; vessels 20-80 μm in diameter with simple perforation plates",
      "zh-Hant": "木栓層為數層細胞；韌皮部有散在的分泌道、韌皮纖維和薄壁組織；木質部有導管、管胞、木纖維和射線；導管直徑20-80微米，單穿孔板"
    },
    "powderCharacteristics": {
      "en": "Powder shows fragments of cork cells, parenchyma cells containing starch grains (simple or compound, 2-20 μm in diameter), vessels with simple perforation plates, and fragments of resin canals",
      "zh-Hont": "粉末可見木栓細胞碎片，含澱粉粒的薄壁細胞（單粒或複粒，直徑2-20微米），具單穿孔板的導管，以及分泌道碎片"
    },
    "diagnosticFeatures": {
      "en": "Presence of secretory canals in phloem; starch grains 2-20 μm in diameter; calcium oxalate cluster crystals 20-70 μm in diameter"
    }
  },

  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification - TLC"
      },
      "testType": "TestType-Identification",
      "harmonizedMethod": "TLC",
      "testConditions": {
        "en": "Extract with methanol. Compare with Ginsenoside Rb1 and Rg1 standard."
      }
    },
    {
      "@type": "PhysicalSpecification",
      "testName": {
        "en": "Foreign Matter"
      },
      "testType": "TestType-ForeignMatter",
      "harmonizedMethod": "ForeignMatter",
      "limit": {
        "@type": "Limit",
        "limitType": "LimitType-NotMoreThan",
        "limitValue": 2.0,
        "limitUnit": "percent"
      }
    },
    {
      "@type": "PhysicalSpecification",
      "testName": {
        "en": "Total Ash"
      },
      "testType": "TestType-Physical",
