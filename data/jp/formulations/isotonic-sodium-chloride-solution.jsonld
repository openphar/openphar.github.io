{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/formulations/isotonic-sodium-chloride-solution",
  "@type": "FormulationMonograph",
  "prefLabel": {
    "en": "Isotonic Sodium Chloride Solution",
    "ja": "生理食塩液"
  },
  "monographId": "JP18-isotonic-sodium-chloride-solution",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "definition": {
    "en": "Isotonic Sodium Chloride Solution is an aqueous in-jection. It contains not less than 0."
  },
  "appearance": {
    "en": "Isotonic Sodium Chloride Solution is a clear, colorless liquid. It has a slightly saline taste."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "Isotonic Sodium Chloride Solution responds to Qualitative Tests <1.09> for sodium salt and for chloride. pH <2.54> 4.5 – 8.0"
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Heavy metals <1.07>—Concentrate 100 mL of Isotonic Sodium Chloride Solution to about 40 mL on a water bath, and add 2 mL of dilute acetic acid and water to make 50 mL. Perform the test using this solution as the test solution. Prepare the control solution with 3.0 mL of Stand-ard Lead Solution and 2 mL of dilute acetic acid, and add water to make 50 mL (not more than 0.3 ppm). (2) Arsenic <1.11>—Prepare the test solution with 20 mL of Isotonic Sodium Chloride Solution, and perform the test (not more than 0.1 ppm). Bacterial endotoxins <4.01> Less than 0.50 EU/mL. Extractable volume <6.05> It meets the requirement. Foreign insoluble matter <6.06> Perform the test according to Method 1: it meets the requirement. Insoluble particulate matter <6.07> It meets the require-ment. Sterility <4.06> Perform the test according to the Mem-brane filtration method: it meets the requirement."
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Measure exactly 20 mL of Isotonic Sodium Chloride Solution, add 30 mL of water, and titrate <2.50> with 0.1 mol/L silver nitrate VS with vigorous shaking (indicator: 3 drops of fluorescein sodium TS). Each mL of 0.1 mol/L silver nitrate VS ＝ 5.844 mg of NaCl"
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Hermetic containers. Plastic containers for aqueous injections may be used."
  },
  "dosageForm": "Solution"
}