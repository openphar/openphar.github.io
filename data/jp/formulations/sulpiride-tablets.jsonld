{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/formulations/sulpiride-tablets",
  "@type": "FormulationMonograph",
  "prefLabel": {
    "en": "Sulpiride Tablets",
    "ja": "スルピリド錠"
  },
  "monographId": "JP18-sulpiride-tablets",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "definition": {
    "en": "Sulpiride Tablets contain not less than 95.0z and not more than 105.0z of the labeled amount of sulpi-ride (C15H23N3O4S: 341.43). Method of preparation Prepare as directed under Tablets, with Sulpiride. Identification Determine the absorption spectrum of the sample solution obtained in the Assay as directed under Ultraviolet-visible Spectrophotometry <2.24>, using water as the blank: it exhibits a maximum between 289 nm and 293 nm. Uniformity of dosage units <6.02> Perform the Mass varia-tion test, or the Content uniformity test according to the fol-lowing method: it meets the requirement. To 1 tablet of Sulpiride Tablets add 30 mL of 0.05 mol/L sulfuric acid TS, shake for 30 minutes, add 0.05 mol/L sul-furic acid TS to make exactly V mL so that each mL contains about 1 mg of sulpiride (C15H23N3O4S), and filter the solu- Assay Weigh accurately, and powder not less than 20 Sul-piride Tablets."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "Determine the absorption spectrum of the sample solution obtained in the Assay as directed under Ultraviolet-visible Spectrophotometry <2.24>, using water as the blank: it exhibits a maximum between 289 nm and 293 nm. Uniformity of dosage units <6.02> Perform the Mass varia-tion test, or the Content uniformity test according to the fol-lowing method: it meets the requirement. To 1 tablet of Sulpiride Tablets add 30 mL of 0.05 mol/L sulfuric acid TS, shake for 30 minutes, add 0.05 mol/L sul-furic acid TS to make exactly V mL so that each mL contains about 1 mg of sulpiride (C15H23N3O4S), and filter the solu-"
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Weigh accurately, and powder not less than 20 Sul-piride Tablets. Weigh accurately a portion of the powder, equivalent to about 0.1 g of sulpiride (C15H23N3O4S), add 70 mL of 0.05 mol/L sulfuric acid TS, shake for 30 minutes, and add 0.05 mol/L sulfuric acid TS to make exactly 100 mL, and filter. Discard the first 20 mL of the filtrate, pipet 5 mL of the subsequent filtrate, add water to make exactly 100 mL, and use this solution as the sample solution. Separately, weigh accurately about 50 mg of sulpiride for assay, previ-ously dried at 1059C for 3 hours, and dissolve in 0.05 mol/L sulfuric acid TS to make exactly 50 mL. Pipet 5 mL of this solution, add water to make exactly 100 mL, and use this so-lution as the standard solution. Determine the absorbances, AT and AS, of the sample solution and standard solution at 291 nm as directed under Ultraviolet-visible Spectropho-tometry <2.24>, using water as the blank. Amount (mg) of sulpiride (C15H23N3O4S) ＝ MS × AT/AS × 2 MS: Amount (mg) of sulpiride for assay taken"
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Tight containers."
  },
  "dosageForm": "Tablet"
}