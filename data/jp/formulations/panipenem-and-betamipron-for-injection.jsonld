  "definition": {
    "en": "Panipenem and Betamipron for Injection is a prepa-ration for injection which is dissolved before use. It contains not less than 90."
  },
  "appearance": {
    "en": "Panipenem and Betamipron for Injection oc-curs as two layers of upper and lower. The former occurs pale yellowish white to light yellow, masses or masses con-taining powder, and the latter white, masses or masses con-taining powder. It is deliquescent."
  },
  "testSpecification": [
