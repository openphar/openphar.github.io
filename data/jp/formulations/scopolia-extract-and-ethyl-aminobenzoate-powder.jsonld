  "@type": "FormulationMonograph",
  "prefLabel": {
    "en": "Scopolia Extract and Ethyl Aminobenzoate Powder",
    "ja": "ロートエキス・アネスタミン散"
  },
  "monographId": "JP18-scopolia-extract-and-ethyl-aminobenzoate-powder",
  "publisher": "JP",
