{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/formulations/loxoprofen-sodium-tablets",
  "@type": "FormulationMonograph",
  "prefLabel": {
    "en": "Loxoprofen Sodium Tablets",
    "ja": "ロキソプロフェンナトリウム錠"
