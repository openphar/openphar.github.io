{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/formulations/vitamin-b2-phosphate-ester-injection",
  "@type": "FormulationMonograph",
  "prefLabel": {
    "en": "Vitamin B2 Phosphate Ester Injection",
    "ja": "リボフラビンリン酸エステルナトリウム注射液"
  },
  "monographId": "JP18-vitamin-b2-phosphate-ester-injection",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "appearance": {
    "en": "Riboflavin Sodium Phosphate Injection is a clear, yellow to orange-yellow liquid. pH: 5.0 – 7.0"
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "(1) To a measured volume of Riboflavin Sodium Phosphate Injection, equivalent to 1 mg of Riboflavin, add water to make 100 mL, and proceed with this solution as directed in the Identification (1) and (2) under Riboflavin Sodium Phosphate. To a measured volume of Riboflavin Sodium Phos-phate Injection, equivalent to 0.05 g of Riboflavin, and evaporate on a water bath to dryness. Proceed with this residue as directed in the Identification (4) under Riboflavin Sodium Phosphate. Bacterial endotoxins <4.01> Less than 10 EU/mg. Extractable volume <6.05> It meets the requirement. Foreign insoluble matter <6.06> Perform the test according to Method 1: it meets the requirement. Insoluble particulate matter <6.07> It meets the require-ment. Sterility <4.06> Perform the test according to the Membrane filtration method: it meets the requirement."
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Conduct this procedure without exposure to light, using light-resistant vessels. To an accurately measured volume of Riboflavin Sodium Phosphate Injection, equiva-lent to about 15 mg of riboflavin (C17H20N4O6), add diluted acetic acid (100) (1 in 500) to make exactly 1000 mL, and use this solution as the sample solution. Proceed as directed in the Assay under Riboflavin Sodium Phosphate. Amount (mg) of Riboflavin (C17H20N4O6) ＝ MS × (AT － AT?)/(AS － AS?) MS: Amount (mg) of Riboflavin RS taken"
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Hermetic containers. Storage—Light-resistant."
  },
  "dosageForm": "Injection"
}