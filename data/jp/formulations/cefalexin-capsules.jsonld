{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/formulations/cefalexin-capsules",
  "@type": "FormulationMonograph",
  "prefLabel": {
    "en": "Cefalexin Capsules",
    "ja": "セファレキシンカプセル"
  },
  "monographId": "JP18-cefalexin-capsules",
