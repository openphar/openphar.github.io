  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/formulations/gentian-and-sodium-bicarbonate-powder",
  "@type": "FormulationMonograph",
  "prefLabel": {
    "en": "Gentian and Sodium Bicarbonate Powder",
    "ja": "ゲンチアナ・重曹散"
  },
  "monographId": "JP18-gentian-and-sodium-bicarbonate-powder",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "appearance": {
    "en": "Gentian and Sodium Bicarbonate Powder oc-curs as a light yellow-brown powder, and has a bitter taste."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "(1) To 2 g of Gentian and Sodium Bicar-bonate Powder add 10 mL of water, stir, and filter: the fil-trate responds to the Qualitative Tests <1.09> (1) for bicar-bonate. (2) To 1.5 g of Gentian and Sodium Bicarbonate Powder add 10 mL of methanol, shake for 5 minutes, filter, and use the filtrate as the sample solution. Separately, dissolve 1 mg of gentiopicroside for thin-layer chromatography in 1 mL of ‌JP XVIII Crude Drugs and Related Drugs / Ginger 2009‌‌ methanol, and use this solution as the standard solution. Perform the test with these solutions as directed under Thin-layer Chromatography <2.03>. Spot 5 mL each of the sample solution and standard solution on a plate of silica gel with fluorescent indicator for thin-layer chromatography. De-velop the plate with a mixture of ethyl acetate, ethanol (99.5) and water (8:2:1) to a distance of about 10 cm, and air-dry the plate. Examine under ultraviolet light (main wavelength: 254 nm): one of the several spots obtained from the sample solution and a spot from the standard solution show the same color tone and the same Rf value."
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Well-closed contain-ers."
  },
  "dosageForm": "Powder"
}