{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/formulations/pethidine-hydrochloride-injection",
  "@type": "FormulationMonograph",
  "prefLabel": {
    "en": "Pethidine Hydrochloride Injection",
    "ja": "ペチジン塩酸塩注射液"
  },
  "monographId": "JP18-pethidine-hydrochloride-injection",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "definition": {
    "en": "Pethidine Hydrochloride Injection is an aqueous in-jection. It contains not less than 95."
  },
  "appearance": {
    "en": "Pethidine Hydrochloride Injection is a clear, colorless liquid. It is affected by light. pH 4.0 – 6.0"
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "Take a volume of Pethidine Hydrochloride Injection equivalent to 0.1 g of Pethidine Hydrochloride, and add water to make 200 mL. Determine the absorption spectrum of this solution as directed under Ultraviolet-visible Spectrophotometry <2.24>: it exhibits maxima be-tween 250 nm and 254 nm, between 255 nm and 259 nm, and between 261 nm and 265 nm. Bacterial endotoxins <4.01> Less than 6.0 EU/mg. Extractable volume <6.05> It meets the requirement. Foreign insoluble matter <6.06> Perform the test according to Method 1: it meets the requirement. Insoluble particulate matter <6.07> It meets the require-ment. Sterility <4.06> Perform the test according to the Mem-brane filtration method: it meets the requirement."
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Measure exactly a volume of Pethidine Hydrochlo-ride Injection, equivalent to about 0.1 g of pethidine hydro-chloride (C15H21NO2.HCl), add exactly 10 mL of the internal standard solution, and add the mobile phase to make 50 mL. To 5 mL of this solution add the mobile phase to make 20 mL, and use this solution as the sample solution. Separately, weigh accurately about 0.1 g of pethidine hydrochloride for assay, previously dried at 1059C for 3 hours, add exactly 10 mL of the internal standard solution, and add the mobile phase to make 50 mL. To 5 mL of this solution add the mo-bile phase to make 20 mL, and use this solution as the stand-ard solution. Perform the test with 20 mL of the sample solu-tion and standard solution as directed under Liquid Chroma- order with the resolution between these peaks being not less than 2.0. System repeatability: When the test is repeated 6 times with 20 mL of the standard solution under the above operat-ing conditions, the relative standard deviation of the ratios of the peak area of pethidine to that of the internal standard is not more than 1.0z."
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Hermetic containers, and colored containers may be used."
  },
  "dosageForm": "Injection"
}