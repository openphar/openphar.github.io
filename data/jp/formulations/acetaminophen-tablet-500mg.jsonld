{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",

  "@id": "https://www.openphar.org/data/monograph/jp/acetaminophen-tablet-500mg",
  "@type": "FormulationMonograph",

  "prefLabel": {
    "en": "Acetaminophen Tablets 500 mg",
    "ja": "アセトアミノフェン錠500mg"
  },

  "altLabel": [
    { "@value": "Paracetamol Tablets 500 mg", "@language": "en" },
    { "@value": "Acetaminophen 500 mg Tablet", "@language": "en" }
  ],

  "monographId": "JP18-4013",
  "publisher": "JP",
  "status": "Official",
  "effectiveDate": "2021-06-25",
  "version": "18",

  "definition": {
    "en": "Acetaminophen Tablets contain not less than 95% and not more than 105% of the labeled amount of Acetaminophen (C8H9NO2)."
  },

  "dosageForm": "Tablet",
  "routeOfAdministration": "Oral",
  "strength": {
    "en": "500 mg per tablet"
  },

  "hasComponent": [
    {
      "@type": "FormulationComponent",
      "componentSubstance": {
        "@id": "https://www.openphar.org/data/monograph/jp/acetaminophen"
      },
      "componentRole": "ActiveIngredient",
      "componentQuantity": 500,
      "componentUnit": "mg",
      "componentStrength": {
        "en": "500 mg per tablet"
      }
    },
    {
      "@type": "FormulationComponent",
      "componentSubstance": {
        "@id": "https://www.openphar.org/data/excipient/lactose-hydrate"
      },
      "componentRole": "Filler",
      "componentPercentage": 45.0
    },
    {
      "@type": "FormulationComponent",
      "componentSubstance": {
        "@id": "https://www.openphar.org/data/excipient/corn-starch"
      },
      "componentRole": "Binder",
      "componentPercentage": 10.0
    },
