{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/chemicals/alum",
  "@type": "ChemicalDrugMonograph",
  "prefLabel": {
    "en": "Alum",
    "ja": "硫酸アルミニウムカリウム水和物"
  },
  "monographId": "JP18-alum",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "molecularFormula": "AlK(SO4)2.12H2O",
  "molecularWeight": 474.39,
  "definition": {
    "en": "Aluminum Potassium Sulfate Hydrate contains not less than 99."
  },
  "appearance": {
    "en": "Aluminum Potassium Sulfate Hydrate occurs as colorless or white, crystals or powder. It is odorless. It has a slightly sweet, strongly astringent taste. It is freely soluble in water, and practically insoluble in ethanol (95) and in diethyl ether. A solution of Aluminum Potassium Sulfate Hydrate (1 in 20) is acid."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "A solution of Aluminum Potassium Sulfate Hydrate (1 in 10) responds to Qualitative Tests <1.09> for aluminum salt, to Qualitative Tests <1.09> (1), (3) and (4) for potassium salt, and to the Qualitative Tests <1.09> (1) and (3) for sulfate."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Heavy metals <1.07>—Proceed with 1.0 g of Aluminum Potassium Sulfate Hydrate according to Method 1, and perform the test. Prepare the control solution with 2.0 mL of Standard Lead Solution (not more than 20 ppm). Iron <1.10>—Prepare the test solution with 1.0 g of Aluminum Potassium Sulfate Hydrate according to Method 1, and perform the test according to Method A. Prepare the control solution with 2.0 mL of Standard Iron Solution (not more than 20 ppm). Arsenic <1.11>—Prepare the test solution with 0.6 g of Aluminum Potassium Sulfate Hydrate, according to Method 1, and perform the test (not more than 3.3 ppm)."
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Weigh accurately about 4.5 g of Aluminum Potas-sium Sulfate Hydrate, and dissolve in water to make exactly 200 mL. Take exactly 20 mL of this solution, and add ex-actly 30 mL of 0.05 mol/L disodium dihydrogen ethylene-diamine tetraacetate VS and 20 mL of acetic acid-ammo-nium acetate buffer solution (pH 4.8), boil for 5 minutes, and cool. Add 55 mL of ethanol (95), and titrate <2.50> with 0.05 mol/L zinc acetate VS (indicator: 2 mL of dithizone TS), until the color of the solution changes from light dark green to light red. Perform a blank determination in the same manner. Each mL of 0.05 mol/L disodium dihydorogen ethylenediamine tetraacetate VS ＝ 23.72 mg of AlK(SO4)2.12H2O"
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Tight containers."
  }
}