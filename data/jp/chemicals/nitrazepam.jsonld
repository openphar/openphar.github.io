{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/chemicals/nitrazepam",
  "@type": "ChemicalDrugMonograph",
  "prefLabel": {
    "en": "‌Nitrazepam‌",
    "ja": "ニトラゼパム"
  },
  "monographId": "JP18-nitrazepam",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "molecularFormula": "C15H11N3O3",
  "molecularWeight": 281.27,
  "appearance": {
    "en": "Nitrazepam occurs as white to light yellow, crystals or crystalline powder. It is odorless. It is freely soluble in acetic acid (100), soluble in acetone and in chloroform, slightly soluble in methanol, in ethanol (95) and in ethanol (99.5), very slightly soluble in diethyl ether, and practically insoluble in water. Melting point: about 2279C (with decomposition)."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "(1) To 3 mL of a solution of Nitrazepam in methanol (1 in 500) add 0.1 mL of sodium hydroxide TS: a yellow color is produced. To 0.02 g of Nitrazepam add 15 mL of dilute hydro-chloric acid, boil for 5 minutes, cool, and filter: the filtrate responds to Qualitative Tests <1.09> for primary aromatic amines. Neutralize 0.5 mL of the filtrate obtained in (2) with sodium hydroxide TS, add 2 mL of ninhydrin TS, and heat on a water bath: a purple color is produced. Determine the absorption spectrum of a solution of Nitrazepam in ethanol (99.5) (1 in 100,000) as directed under Ultraviolet-visible Spectrophotometry <2.24>, and compare the spectrum with the Reference Spectrum: both spectra exhibit similar intensities of absorption at the same wave-lengths."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Clarity and color of solution—Dissolve 0.10 g of Nitrazepam in 20 mL of acetone: the solution is clear and pale yellow to light yellow in color. Heavy metals <1.07>—Proceed with 1.0 g of Nitra- zepam according to Method 2, and perform the test. Prepare the control solution with 2.0 mL of Standard Lead Solution (not more than 20 ppm). Arsenic <1.11>—Prepare the test solution with 1.0 g of Nitrazepam according to Method 3, and perform the test (not more than 2 ppm). Related substances—Dissolve 0.25 g of Nitrazepam in a 10 mL of mixture of methanol and chloroform (1:1), and use this solution as the sample solution. Pipet 1 mL of the sample solution, add a mixture of methanol and chlo-roform (1:1) to make exactly 20 mL, pipet 2 mL of this solu-tion, add a mixture of methanol and chloroform (1:1) to make exactly 50 mL, and use this solution as the standard solution. Perform the test with these solutions as directed under Thin-layer Chromatography <2.03>. Spot 10 mL each of the sample solution and standard solution on a plate of silica gel with fluorescent indicator for thin-layer chromatog-raphy. Develop the plate with a mixture of nitromethane and ethyl acetate (17:3) to a distance of about 10 cm, and air-dry the plate. Examine under ultraviolet light (main wavelength: Nitrendipine"
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Weigh accurately about 0.4 g of Nitrazepam, previ-ously dried, and dissolve in 40 mL of acetic acid (100). Titrate <2.50> with 0.1 mol/L perchloric acid VS (potentio-metric titration). Perform a blank determination in the same manner, and make any necessary correction. Each mL of 0.1 mol/L perchloric acid VS ＝ 28.13 mg of C15H11N3O3"
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Tight containers. Storage—Light-resistant."
  }
}