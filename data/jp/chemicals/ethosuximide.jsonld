{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/chemicals/ethosuximide",
  "@type": "ChemicalDrugMonograph",
  "prefLabel": {
    "en": "Ethosuximide",
    "ja": "エトスクシミド"
  },
  "monographId": "JP18-ethosuximide",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "molecularFormula": "C7H11NO2",
  "molecularWeight": 141.17,
  "definition": {
    "en": "Ethosuximide contains not less than 98."
  },
  "appearance": {
    "en": "Ethosuximide occurs as a white, paraffin-like solid or powder. It is odorless or has a slight, characteristic odor. It is very soluble in methanol, in ethanol (95), in diethyl ether, and in N,N-dimethylformamide, and freely soluble in water. Melting point: about 489C"
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "(1) To 0.2 g of Ethosuximide add 10 mL of sodium hydroxide TS, and boil: the gas evolved turns a moistened red litmus paper blue. Dissolve 0.05 g of Ethosuximide in 1 mL of ethanol (95), add 3 drops of a solution of copper (II) acetate mono-hydrate (1 in 100), warm slightly, and add 1 to 2 drops of so-dium hydroxide TS: a purple color is produced. Determine the absorption spectrum of a solution of Ethosuximide in ethanol (95) (1 in 2000) as directed under Ultraviolet-visible Spectrophotometry <2.24>, and compare the spectrum with the Reference Spectrum: both spectra exhibit similar intensities of absorption at the same wave-lengths."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Clarity and color of solution—Dissolve 1.0 g of Ethosuximide in 10 mL of water: the solution is clear and colorless. Chloride <1.03>—With 1.0 g of Ethosuximide, per- form the test. Prepare the control solution with 0.30 mL of 0.01 mol/L hydrochloric acid VS (not more than 0.011z). JP XVIII Official Monographs / Ethylcellulose 971 ‌Heavy metals <1.07>—Proceed with 1.0 g of Ethosux-imide according to Method 1, and perform the test. Prepare the control solution with 2.0 mL of Standard Lead Solution (not more than 20 ppm).‌ Arsenic <1.11>—Prepare the test solution with 1.0 g of Ethosuximide, according to Method 1, and perform the test (not more than 2 ppm). Acid anhydride—Dissolve 0.50 g of Ethosuximide in 1 mL of ethanol (95), add 1 mL of hydroxylammonium chlo-ride-iron (III) chloride TS, and allow to stand for 5 minutes. Add 3 mL of water, mix, and allow to stand for 5 minutes: the red to red-purple color of this solution is not more in-tense than that of the following control solution. Control solution: Dissolve 70 mg of succinic anhydride in ethanol (95) to make exactly 100 mL. To 1.0 mL of this solu-tion add 1 mL of hydroxylammonium chloride-iron (III) chloride TS, and proceed in the same manner. Cyanide—Dissolve 1.0 g of Ethosuximide in 10 mL of ethanol (95), and add 3 drops of iron (II) sulfate TS, 1 mL of sodium hydroxide TS and 2 to 3 drops of iron (III) chlo-ride TS. Warm gently, and acidify with dilute sulfuric acid: not a blue precipitate and a blue color are produced within 15 minutes. Water <2.48> Not more than 0.5z (2 g, volumetric titra-tion, direct titration). Residue on ignition <2.44> Not more than 0.1z (1 g)."
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Weigh accurately about 0.2 g of Ethosuximide, dis-solve in 20 mL of N,N-dimethylformamide, and titrate <2.50> with 0.1 mol/L tetramethylammonium hydroxide VS (potentiometric titration). Perform a blank determination in the same manner, and make any necessary correction. Each mL of 0.1 mol/L tetramethylammonium hydroxide VS ＝ 14.12 mg of C7H11NO2"
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Tight containers."
  }
}