{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/chemicals/protirelin",
  "@type": "ChemicalDrugMonograph",
  "prefLabel": {
    "en": "Protirelin",
    "ja": "プロチレリン"
  },
  "monographId": "JP18-protirelin",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "molecularFormula": "C16H22N6O4",
  "molecularWeight": 362.38,
  "definition": {
    "en": "Protirelin contains not less than 98."
  },
  "appearance": {
    "en": "Protirelin occurs as a white powder. It is freely soluble in water, in methanol, in ethanol (95) and in acetic acid (100). It is hygroscopic."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "(1) Take 0.01 g of Protirelin in a test tube made of hard glass, add 0.5 mL of 6 mol/L hydrochloric acid TS, seal the upper part of the tube, and heat carefully at 1109C for 5 hours. After cooling, open the seal, transfer the contents into a beaker, and evaporate on a water bath to dryness. Dissolve the residue in 1 mL of water, and use this solution as the sample solution. Separately, dissolve 0.08 g of L-glutamic acid, 0.12 g of L-histidine hydrochloride monohydrate and 0.06 g of L-proline in 20 mL of water, and use this solution as the standard solution. Perform the test with these solutions as directed under Thin-layer Chroma-tography <2.03>. Spot 5 mL each of the sample solution and standard solution on a plate of silica gel for thin-layer chromatography. Develop the plate with a mixture of 1-butanol, water, acetic acid (100) and pyridine (4:1:1:1) to a distance of about 12 cm, and dry the plate at 1009C for 30 minutes. Spray evenly a solution of ninhydrin in acetone (1 in 50) on the plate, and heat the plate at 809C for 5 minutes: the three spots obtained from the sample solution show the same color and the same Rf value as each corresponding spots from the standard solution. Determine the infrared absorption spectrum of Pro-tirelin, as directed in the potassium bromide disk method under Infrared Spectrophotometry <2.25>, and compare the spectrum with the Reference Spectrum: both spectra exhibit similar intensities of absorption at the same wave numbers. D Optical rotation <2.49> [a]20: －66.0 – －69.09(0.1 g, calcu- ‌lated on the anhydrous basis, water, 20 mL, 100 mm). pH <2.54> Dissolve 0.20 g of Protirelin in 10 mL of water: the pH of this solution is between 7.5 and 8.5."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Clarity and color of solution—Dissolve 0.10 g of Protirelin in 10 mL of water: the solution is clear and col-orless. Heavy metals <1.07>—Proceed with 1.0 g of Protire- lin according to Method 2, and perform the test. Prepare the control solution with 2.0 mL of Standard Lead Solution (not more than 20 ppm). Related substances—Dissolve 0.20 g of Protirelin in 10 mL of water, and use this solution as the sample solution. Pipet 1 mL of the sample solution, add water to make ex-actly 200 mL, and use this solution as the standard solution. Perform the test with these solutions as directed under Thin-layer Chromatography <2.03>. Spot 5 mL each of the sample solution and standard solution on a plate (1) of silica gel for thin-layer chromatography, and spot 5 mL of the sample so-lution on a plate (2) of silica gel for thin-layer chromatogra-phy. Develop the plates with a mixture of 1-butanol, water, pyridine and acetic acid (100) (4:2:1:1) to a distance of about 12 cm, and dry the plates at 1009C for 30 minutes. Spray evenly a mixture of a solution of sulfanilic acid in 1 mol/L hydrochloric acid TS (1 in 200) and a solution of sodium nitrite (1 in 20) (1:1) on the plate (1), and air-dry the plates. Successively spray evenly a solution of sodium carbonate decahydrate (1 in 10) on it: the spots other than the principal spot obtained from the sample solution are not more intense than the spot from the standard solution. Spray evenly a so-lution of ninhydrin in acetone (1 in 50) on the plate (2), and heat the plate at 809C for 5 minutes: no colored spot ap-pears. Water <2.48> Not more than 5.0z (0.1 g, volumetric titra-tion, direct titration). Residue on ignition <2.44> Not more than 0.3z (0.2 g)."
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Weigh accurately about 70 mg of Protirelin dissolve in 50 mL of acetic acid (100), and titrate <2.50> with 0.02 mol/L perchloric acid VS (potentiometric titration). Per-form a blank determination in the same manner, and make any necessary correction. Each mL of 0.02 mol/L perchloric acid VS ＝ 7.248 mg of C16H22N6O4"
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Tight containers."
  }
}