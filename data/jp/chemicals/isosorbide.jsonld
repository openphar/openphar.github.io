{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/chemicals/isosorbide",
  "@type": "ChemicalDrugMonograph",
  "prefLabel": {
    "en": "Isosorbide",
    "ja": "イソソルビド"
  },
  "monographId": "JP18-isosorbide",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "molecularFormula": "C6H10O4",
  "molecularWeight": 146.14,
  "definition": {
    "en": "Isosorbide contains not less than 98."
  },
  "appearance": {
    "en": "Isosorbide occurs as white, crystals or masses. It is odorless, or has a faint, characteristic odor, and has a bitter taste. It is very soluble in water and in methanol, freely soluble in ethanol (95), and slightly soluble in diethyl ether. It is hygroscopic."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "(1) To 0.1 g of Isosorbide add 6 mL of diluted sulfuric acid (1 in 2), and dissolve by heating in a water bath. After cooling, shake well with 1 mL of a solu-tion of potassium permanganate (1 in 30), and heat in a water bath until the color of potassium permanganate disap-pears. To this solution add 10 mL of 2,4-dinitrophenyl-hydrazine TS, and heat in a water bath: an orange precipi-tate is formed. To 2 g of Isosorbide add 30 mL of pyridine and 4 mL of benzoyl chloride, boil under a reflux condenser for 50 minutes, cool, and pour gradually the solution into 100 mL of cold water. Filter the formed precipitate by suction through a glass filter (G3), wash with water, recrystallize twice from ethanol (95), and dry in a desiccator (in vacuum, silica gel) for 4 hours: it melts <2.60> between 1029C and 1039C. Determine the infrared absorption spectrum of Isosorbide as directed in the potassium bromide disk method under Infrared Spectrophotometry <2.25>, and compare the spectrum with the Reference Spectrum: both spectra exhibit similar intensities of absorption at the same wave numbers. D Optical rotation <2.49> [a]20: ＋45.0 – ＋46.09(5 g calcu-lated on the anhydrous basis, water, 50 mL, 100 mm)."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Clarity and color of solution—Take 25 g of Isosorbide in a Nessler tube, and dissolve in 50 mL of water: the solution is clear, and has no more color than the follow-ing control solution. Control solution: To a mixture of 1.0 mL of Cobalt (II) Chloride CS, 3.0 mL of Iron (III) Chloride CS and 2.0 mL of Copper (II) Sulfate CS add water to make 10.0 mL. To 3.0 mL of this solution add water to make 50 mL. Sulfate <1.14>—Perform the test with 2.0 g of Isosor-bide. Prepare the control solution with 1.0 mL of 0.005 mol/L sulfuric acid VS (not more than 0.024z). Heavy metals <1.07>—Proceed with 5.0 g of Isosor-bide according to Method 1, and perform the test. Prepare the control solution with 2.5 mL of Standard Lead Solution (not more than 5 ppm). Arsenic <1.11>—Prepare the test solution with 1.0 g of Isosorbide according to Method 1, and perform the test (not more than 2 ppm). Related substances—Dissolve 0.10 g of Isosorbide in 10 mL of methanol, and use this solution as the sample solu-tion. Pipet 2 mL of the sample solution, add methanol to make exactly 100 mL, and use this solution as the standard solution. Perform the test with these solutions as directed under Thin-layer Chromatography <2.03>. Spot 10 mL each of the sample solution and standard solution on a plate of silica gel for thin-layer chromatography. Develop the plate with a mixture of ethanol (95) and cyclohexane (1:1) to a dis-tance of about 10 cm, and air-dry the plate. Spray evenly a mixture of ethanol (95) and sulfuric acid (9:1) on the plate, and heat the plate at 1509C for 30 minutes: the spots other than the principal spot obtained from the sample solution are not more intense than the spot from the standard solu-tion. Water <2.48> Not more than 1.5z (2 g, volumetric titra-tion, direct titration). Residue on ignition <2.44> Not more than 0.1z (1 g)."
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Weigh accurately about 10 g of Isosorbide, calcu-lated on the anhydrous basis, and dissolve in water to make exactly 100 mL. Determine the optical rotation <2.49>, aD, of this solution at 20 ± 19C in a 100-mm cell. Amount (g) of isosorbide (C6H10O4) ＝ aD × 2.1978"
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Tight containers."
  }
}