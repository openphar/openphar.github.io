{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/chemicals/iopamidol",
  "@type": "ChemicalDrugMonograph",
  "prefLabel": {
    "en": "Iopamidol",
    "ja": "イオパミドール"
  },
  "monographId": "JP18-iopamidol",
