{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/chemicals/stearyl-alcohol",
  "@type": "ChemicalDrugMonograph",
  "prefLabel": {
    "en": "Stearyl Alcohol",
    "ja": "ステアリルアルコール"
  },
  "monographId": "JP18-stearyl-alcohol",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "appearance": {
    "en": "Stearyl Alcohol occurs as a white unctuous matter. It has a faint, characteristic odor. It is tasteless. It is freely soluble in ethanol (95), in ethanol (99.5) and in diethyl ether, and practically insoluble in water."
  },
  "testSpecification": [
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Clarity of solution—Dissolve 3.0 g of Stearyl Alcohol in 25 mL of ethanol (99.5) by warming: the solution is clear. (2) Alkalinity—To the solution obtained in (1) add 2 drops of phenolphthalein TS: no red color develops. Residue on ignition <2.44> Not more than 0.05z (2 g)."
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Well-closed contain-ers."
  }
}