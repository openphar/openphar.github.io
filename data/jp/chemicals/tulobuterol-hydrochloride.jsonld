{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/chemicals/tulobuterol-hydrochloride",
  "@type": "ChemicalDrugMonograph",
  "prefLabel": {
    "en": "‌Tulobuterol Hydrochloride‌",
    "ja": "ツロブテロール塩酸塩"
  },
  "monographId": "JP18-tulobuterol-hydrochloride",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "molecularFormula": "C12H18ClNO.HCl",
  "molecularWeight": 264.19,
  "appearance": {
    "en": "Tulobuterol Hydrochloride occurs as white, crystals or crystalline powder. It is very soluble in methanol, freely soluble in water, in ethanol (95) and in acetic acid (100), sparingly soluble in ace-tic anhydride. A solution of Tulobuterol Hydrochloride (1 in 20) shows no optical rotation. Melting point: about 1639C."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "(1) Determine the absorption spectrum of a solution of Tulobuterol Hydrochloride (1 in 2500) as di-rected under Ultraviolet-visible Spectrophotometry <2.24>, and compare the spectrum with the Reference Spectrum: both spectra exhibit similar intensities of absorption at the same wavelengths. Determine the infrared absorption spectrum of Tulobuterol Hydrochloride, previously dried, as directed in the potassium bromide disk method under Infrared Spectro-photometry <2.25>, and compare the spectrum with the Ref-erence Spectrum: both spectra exhibit similar intensities of absorption at the same wave numbers. A solution of Tulobuterol Hydrochloride (1 in 20) responds to Qualitative Tests <1.09> for chloride."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Clarity and color of solution—Dissolve 1.0 g of Tulobuterol Hydrochloride in 10 mL of water: the solution is clear and colorless. Heavy metals <1.07>—Proceed with 2.0 g of Tulobuterol Hydrochloride according to Method 1, and per-form the test. Prepare the control solution with 2.0 mL of Standard Lead Solution (not more than 10 ppm). Related substances—Dissolve 30 mg of Tulobuterol Hydrochloride in 50 mL of the mobile phase, and use this solution as the sample solution. Pipet 1 mL of the sample so-lution, add the mobile phase to make exactly 100 mL. Pipet 5 mL of this solution, add the mobile phase to make exactly 50 mL, and use this solution as the standard solution. Per-form the test with exactly 25 mL each of the sample solution and standard solution as directed under Liquid Chro-matography <2.01> according to the following conditions, and determine each peak area by the automatic integration method: the area of the peak other than tulobuterol obtained from the sample solution is not larger than the peak area of tulobuterol from the standard solution, and the total area of the peaks other than the peak of tulobuterol from the sample solution is not larger than 5 times the peak area of tulobuterol from the standard solution. Operating conditions— Detector: An ultraviolet absorption photometer (wave-length: 215 nm). add the mobile phase to make 10 mL, and use this solution as the solution for system suitability test. When the proce-dure is run with 25 mL of the solution for system suitability test under the above operating conditions, the number of theoretical plates and the symmetry factor of the peak of tulobuterol are not less than 5000 and not more than 2.0, respectively. System repeatability: When the test is repeated 6 times with 25 mL of the solution for system suitability test under the above operating conditions, the relative standard devia-tion of the peak area of tulobuterol is not more than 2.0z. Loss on drying <2.41> Not more than 0.5z (0.5 g, in vacu-um, 609C, 4 hours). Residue on ignition <2.44> Not more than 0.1z (1 g)."
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Weigh accurately about 0.5 g of Tulobuterol Hydro-chloride, previously dried, dissolve in 80 mL of a mixture of acetic anhydride and acetic acid (100) (7:3), and titrate <2.50> with 0.1 mol/L perchloric acid VS (potentiometric titration). Perform a blank determination in the same manner, and make any necessary correction. Each mL of 0.1 mol/L perchloric acid VS ＝ 26.42 mg of C12H18ClNO.HCl"
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Tight containers."
  }
}