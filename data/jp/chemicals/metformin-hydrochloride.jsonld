{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/chemicals/metformin-hydrochloride",
  "@type": "ChemicalDrugMonograph",
  "prefLabel": {
    "en": "Metformin Hydrochloride",
    "ja": "メトホルミン塩酸塩"
  },
  "monographId": "JP18-metformin-hydrochloride",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "molecularFormula": "C4H11N5.HCl",
  "molecularWeight": 165.62,
  "definition": {
    "en": "Metformin Hydrochloride, when dried, contains not less than 98."
  },
  "appearance": {
    "en": "Metformin Hydrochloride occurs as white, crystals or crystalline powder. It is freely soluble in water, sparingly soluble in acetic acid (100), and slightly soluble in ethanol (99.5). Melting point: about 2219C (with decomposition)."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "(1) Determine the absorption spectrum of a solution of Metformin Hydrochloride (1 in 100,000) as di-rected under Ultraviolet-visible Spectrophotometry <2.24>, and compare the spectrum with the Reference Spectrum: both spectra exhibit similar intensities of absorption at the same wavelengths. Determine the infrared absorption spectrum of Met-formin Hydrochloride as directed in the potassium chloride disk method under Infrared Spectrophotometry <2.25>, and compare the spectrum with the Reference Spectrum: both spectra exhibit similar intensities of absorption at the same wave numbers. A solution of Metformin Hydrochloride (1 in 50) responds to Qualitative Tests <1.09> for chloride."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Heavy metals <1.07>—Proceed with 2.0 g of Metformin Hydrochloride according to Method 1, and per-form the test. Prepare the control solution with 2.0 mL of Standard Lead Solution (not more than 10 ppm). (2) Related substances—Dissolve 2.5 g of Metformin not more intense than the spot from the standard solution (1), the number of them showing more intense than the spot from the standard solution (2) is not more than two, and the spot from the sample solution appeared at the position cor-responding to the spot from the standard solution (3) is not more intense than the spot from the standard solution (3). Loss on drying <2.41> Not more than 0.5z (1 g, 1059C, 3 hours). Residue on ignition <2.44> Not more than 0.1z (1 g)."
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Weigh accurately about 0.1 g of Metformin Hydro-chloride, previously dried, dissolve in 40 mL of acetic acid (100), add 40 mL of acetic anhydride, and titrate <2.50> with 0.05 mol/L perchloric acid VS (potentiometric titration). Perform a blank determination in the same manner, and make any necessary correction. Each mL of 0.05 mol/L perchloric acid VS ＝ 4.141 mg of C4H11N5.HCl"
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Tight containers."
  }
}