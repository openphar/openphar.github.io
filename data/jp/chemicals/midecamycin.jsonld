{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/chemicals/midecamycin",
  "@type": "ChemicalDrugMonograph",
  "prefLabel": {
    "en": "Midecamycin",
    "ja": "ミデカマイシン"
  },
  "monographId": "JP18-midecamycin",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "molecularFormula": "C41H67NO15",
  "molecularWeight": 813.97,
  "definition": {
    "en": "Midecamycin is a macrolide substance having anti-bacterial activity produced by the growth of Strep-tomyces mycarofaciens. It contains not less than 950 mg (potency) and not more than 1020 mg (potency) per mg, calculated on the dried basis."
  },
  "appearance": {
    "en": "Midecamycin occurs as a white crystalline powder. It is very soluble in methanol, freely soluble in ethanol (95), and very slightly soluble in water."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "(1) Determine the absorption spectrum of a solution of Midecamycin in methanol (1 in 50,000) as di-rected under Ultraviolet-visible Spectrophotometry <2.24>, and compare the spectrum with the Reference Spectrum or the spectrum of a solution of Midecamycin RS prepared in the same manner as the sample solution: both spectra exhibit similar intensities of absorption at the same wavelengths. Determine the infrared absorption spectrum of Midecamycin as directed in the potassium bromide disk method under Infrared Spectrophotometry <2.25>, and com-pare the spectrum with the Reference Spectrum or the spec-trum of Midecamycin RS: both spectra exhibit similar inten-sities of absorption at the same wave numbers. ‌"
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "Heavy metals <1.07>—Proceed with 1.0 g of Midecamycin according to Method 2, and perform the test. Prepare the control solution with 3.0 mL of Standard Lead Solution (not more than 30 ppm). Loss on drying <2.41> Not more than 2.0z (1.0 g, in vacu-um not exceeding 0.67 kPa, 609C, 3 hours). Residue on ignition <2.44> Not more than 0.2z (1 g)."
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Perform the test according to the Cylinder-plate method as directed under Microbial Assay for Antibiotics <4.02> according to the following conditions. Test organism—Bacillus subtilis ATCC 6633 Culture medium—Use the medium i in 1) under (1) Agar media for seed and base layer. Standard solutions—Weigh accurately an amount of Midecamycin RS, previously dried, equivalent to about 20 mg (potency), dissolve in 10 mL of methanol, add water to make exactly 50 mL, and use this solution as the standard Midecamycin Acetate"
      }
    }
  ]
}