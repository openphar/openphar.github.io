  "prefLabel": {
    "en": "Etizolam",
    "ja": "エチゾラム"
  },
  "monographId": "JP18-etizolam",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "molecularFormula": "C17H15ClN4S",
  "molecularWeight": 342.85,
  "definition": {
    "en": "Etizolam, when dried, contains not less than 98."
  },
  "appearance": {
    "en": "Etizolam occurs as a white to pale yellow-white crystalline powder. It is soluble in ethanol (99.5), sparingly soluble in aceto-nitrile and in acetic anhydride, and practically insoluble in water."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "(1) Determine the absorption spectrum of a solution of Etizolam in ethanol (99.5) (1 in 100,000) as di-rected under Ultraviolet-visible Spectrophotometry <2.24>, and compare the spectrum with the Reference Spectrum: both spectra exhibit similar intensities of absorption at the same wavelengths. (2) Determine the infrared absorption spectrum of Etizolam as directed in the potassium bromide disk method under Infrared Spectrophotometry <2.25>, and compare the spectrum with the Reference Spectrum: both spectra exhibit similar intensities of absorption at the same wave numbers."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Heavy metals <1.07>—Proceed with 2.0 g of Etizolam according to Method 2, and perform the test. Pre-pare the control solution with 2.0 mL of Standard Lead So-lution (not more than 10 ppm). (2) Related substances—Dissolve 20 mg of Etizolam in 50 mL of acetonitrile, and use this solution as the sample so-lution. Pipet 1 mL of the sample solution, and add aceto- area of etizolam is not more than 2z. Loss on drying <2.41> Not more than 0.5z (1 g, 1059C, 3 hours). Residue on ignition <2.44> Not more than 0.1z (1 g)."
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Weigh accurately about 0.3 g of Etizolam, previ-ously dried, dissolve in 70 mL of a mixture of acetic anhy-dride and acetic acid (100) (7:3), and titrate <2.50> with 0.1 mol/L perchloric acid VS (potentiometric titration). The end point is the second equivalent point. Perform a blank deter-mination in the same manner, and make any necessary cor-rection. Each mL of 0.1 mol/L perchloric acid VS ＝ 17.14 mg of C17H15ClN4S"
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Tight containers. Storage—Light-resistant."
  }
}