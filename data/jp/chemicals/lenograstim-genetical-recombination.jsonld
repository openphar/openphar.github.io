{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/chemicals/lenograstim-genetical-recombination",
  "@type": "ChemicalDrugMonograph",
  "prefLabel": {
    "en": "Lenograstim (Genetical Recombination)",
    "ja": "レノグラスチム（遺伝子組換え）"
  },
  "monographId": "JP18-lenograstim-genetical-recombination",
  "publisher": "JP",
