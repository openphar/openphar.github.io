  "@type": "ChemicalDrugMonograph",
  "prefLabel": {
    "en": "Tacrolimus Hydrate",
    "ja": "タクロリムス水和物"
  },
  "monographId": "JP18-tacrolimus-hydrate",
  "publisher": "JP",
