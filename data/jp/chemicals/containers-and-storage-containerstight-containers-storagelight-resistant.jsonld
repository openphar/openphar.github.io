  "prefLabel": {
    "en": "Containers and storage Containers—Tight containers. Storage—Light-resistant.",
    "ja": "ジヒドロコデインリン酸塩散 1"
  },
  "monographId": "JP18-containers-and-storage-containerstight-containers-storagelight-resistant",
