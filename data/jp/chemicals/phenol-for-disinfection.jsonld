{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/chemicals/phenol-for-disinfection",
  "@type": "ChemicalDrugMonograph",
  "prefLabel": {
    "en": "Phenol for Disinfection",
    "ja": "消毒用フェノール"
  },
  "monographId": "JP18-phenol-for-disinfection",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "definition": {
    "en": "Phenol for Disinfection contains not less than 95."
  },
  "appearance": {
    "en": "Phenol for Disinfection occurs as colorless to slightly, red crystals, crystalline masses, or liquid containing ‌these crystals. It has a characteristic odor.‌‌ It is very soluble in ethanol (95) and in diethyl ether, and freely soluble in water. Phenol for Disinfection (10 g) is liquefied by addition of 1 mL of water. It cauterizes the skin, turning it white. Congealing point: about 309C."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "(1) To 10 mL of a solution of Phenol for Disinfection (1 in 100) add 1 drop of iron (III) chloride TS: a blue-purple color is produced. (2) To 5 mL of a solution of Phenol for Disinfection (1 in 10,000) add bromine TS dropwise: a white precipitate is formed, and it dissolves at first upon shaking but becomes permanent as excess of the reagent is added."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Clarity of solution—Dissolve 1.0 g of Phenol for Disinfection in 15 mL of water: the solution is clear. (2) Residue on evaporation—Weigh accurately about 5 g of Phenol for Disinfection, evaporate on a water bath, and stopper immediately, shake for 30 minutes, and allow to stand for 15 minutes. Add 7 mL of potassium iodide TS, stopper tightly at once, shake well, and titrate <2.50> the lib-erated iodine with 0.1 mol/L sodium thiosulfate VS (indica-tor: 1 mL of starch TS). Perform a blank determination in the same manner. Each mL of 0.05 mol/L bromine VS ＝ 1.569 mg of C6H6O"
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Tight containers."
  }
}