  "@type": "ChemicalDrugMonograph",
  "prefLabel": {
    "en": "Sulfamethizole",
    "ja": "スルファメチゾール"
  },
  "monographId": "JP18-sulfamethizole",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "molecularFormula": "C9H10N4O2S2",
  "molecularWeight": 270.33,
  "casNumber": "144-82-1",
  "definition": {
    "en": "Sulfamethizole, when dried, contains not less than 99."
  },
  "appearance": {
    "en": "Sulfamethizole occurs as white to yellowish white, crystals or crystalline powder. It is odorless. It is slightly soluble in ethanol (95), and in acetic acid (100) and practical insoluble in water and in diethyl ether. It dissolves in dilute hydrochloric acid and in sodium hy-droxide TS. It is gradually colored by light."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "Determine the infrared absorption spectrum of Sulfamethizole, previously dried, as directed in the potas-sium bromide disk method under Infrared Spectrophotome-try <2.25>, and compare the spectrum with the Reference Spectrum: both spectra exhibit similar intensities of absorp-tion at the same wave numbers."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Clarity and color of solution—Dissolve 0.5 g of Sulfamethizole in 3 mL of sodium hydroxide TS and 20 mL of water: the solution is clear and colorless. Acidity—To 1.0 g of Sulfamethizole add 50 mL of water, warm at 709C for 5 minutes, allow to stand for 1 hour in an ice bath, and filter. To 25 mL of the filtrate add 2 drops of methyl red TS and 0.60 mL of 0.1 mol/L sodium hydroxide VS: a yellow color develops. Heavy metals <1.07>—Proceed with 1.0 g of Sul- famethizole according to Method 2, and perform the test. Prepare the control solution with 2.0 mL of Standard Lead Solution (not more than 20 ppm). Arsenic <1.11>—Prepare the test solution with 1.0 g of Sulfamethizole according to Method 3, and perform the test (not more than 2 ppm). Related substances—Dissolve 0.10 g of Sulfamethi-zole in 10 mL of acetone, and use this solution as the sample solution. Pipet 1 mL of the sample solution, add acetone to make exactly 50 mL, then pipet 5 mL of this solution, add acetone to make exactly 20 mL, and use this solution as the standard solution. Perform the test with these solutions as directed under Thin-layer Chromatography <2.03>. Spot 5 mL each of the sample solution and standard solution on a plate of silica gel with fluorescent indicator for thin-layer Amount (mg) of sulfadiazine silver (C ＝ MS × AT/AS 10H9AgN4O2S) chromatography. Develop the plate with a mixture of ethyl acetate and acetic acid (100) (20:1) to a distance of about 10 cm, and air-dry the plate. Examine under ultraviolet light MS: Amount (mg) of Sulfadiazine Silver RS taken (main wavelength: 254 nm): the spots other than the princi-pal spot obtained from the sample solution are not more ‌intense than the spot from the standard solution.‌ Loss on drying <2.41> Not more than 0.5z (1 g, 1059C, 4 hours). Residue on ignition <2.44> Not more than 0.1z (1 g)."
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Weigh accurately about 0.4 g of Sulfamethizole, previously dried, dissolve in 5 mL of hydrochloric acid and 50 mL of water, add 10 mL of a solution of potassium bro-mide (3 in 10), cool below 159C, and titrate <2.50> with 0.1 mol/L sodium nitrite VS according to the potentiometric titration method or the amperometric titration method. Each mL of 0.1 mol/L sodium nitrite VS ＝ 27.03 mg of C9H10N4O2S2"
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Well-closed contain-ers."
  }
}