{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/chemicals/alminoprofen",
  "@type": "ChemicalDrugMonograph",
  "prefLabel": {
    "en": "Alminoprofen",
    "ja": "アルミノプロフェン"
  },
  "monographId": "JP18-alminoprofen",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "molecularFormula": "C13H17NO2",
  "molecularWeight": 219.28,
  "definition": {
    "en": "Alminoprofen, when dried, contains not less than 99."
  },
  "appearance": {
    "en": "Alminoprofen occurs as white to pale yellow, crystals or crystalline powder. It is freely soluble in ethanol (99.5) and in acetic acid (100), and very slightly soluble in water. It gradually turns brown on exposure to light. A solution of Alminoprofen in ethanol (99.5) (1 in 10) shows no optical rotation."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "(1) Determine the absorption spectrum of a solution of Alminoprofen in ethanol (99.5) (3 in 500,000) as directed under Ultraviolet-visible Spectrophotometry <2.24>, and compare the spectrum with the Reference Spectrum: both spectra exhibit similar intensities of absorption at the same wavelengths. Determine the infrared absorption spectrum of Alminoprofen as directed in the potassium bromide disk method under Infrared Spectrophotometry <2.25>, and com-pare the spectrum with the Reference Spectrum: both spectra exhibit similar intensities of absorption at the same wave numbers."
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Weigh accurately about 0.3 g of Alminoprofen, previously dried, dissolve in 50 mL of acetic acid (100), and titrate <2.50> with 0.1 mol/L perchloric acid VS (potentio-metric titration). Perform a blank determination in the same manner, and make any necessary correction. Each mL of 0.1 mol/L perchloric acid VS ＝ 21.93 mg of C13H17NO2 ‌JP XVIII Official Monographs / Alminoprofen Tablets 433"
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Well-closed contain-ers."
  }
}