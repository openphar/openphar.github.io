{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/chemicals/bufetolol-hydrochloride",
  "@type": "ChemicalDrugMonograph",
  "prefLabel": {
    "en": "Bufetolol Hydrochloride",
    "ja": "ブフェトロール塩酸塩"
  },
  "monographId": "JP18-bufetolol-hydrochloride",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "molecularFormula": "C18H29NO4.HCl",
  "molecularWeight": 359.89,
  "definition": {
    "en": "Bufetolol Hydrochloride, when dried, contains not less than 98."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "(1) To 5 mL of a solution of Bufetolol Hydrochloride (1 in 100) add 5 drops of Reinecke salt TS: a light red precipitate is formed. Determine the absorption spectrum of a solution of Bufetolol Hydrochloride (1 in 20,000) as directed under Ul-traviolet-visible Spectrophotometry <2.24>, and compare the spectrum with the Reference Spectrum: both spectra exhibit similar intensities of absorption at the same wavelengths. Determine the infrared absorption spectrum of Bufetolol Hydrochloride, previously dried, as directed in the potassium chloride disk method under Infrared Spectropho- JP XVIII Official Monographs / Buformin Hydrochloride 573 tometry <2.25>, and compare the spectrum with the Refer-ence Spectrum: both spectra exhibit similar intensities of ab-sorption at the same wave numbers. ‌A solution of Bufetolol Hydrochloride (1 in 50) re-sponds to Qualitative Tests <1.09> for chloride."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Clarity and color of solution—Dissolve 1.0 g of Bucumolol Hydrochloride in 20 mL of water: the solution is clear and colorless to pale yellow. Heavy metals <1.07>—Proceed with 1.0 g of Bucumolol Hydrochloride according to Method 2, and perform the test. Prepare the control solution with 2.0 mL of Standard Lead Solution (not more than 20 ppm). Arsenic <1.11>—Prepare the test solution with 1.0 g of Bucumolol Hydrochloride according to Method 3, and perform the test (not more than 2 ppm). Related substances—Dissolve 0.10 g of Bucumolol Hydrochloride in 10 mL of methanol, and use this solution as the sample solution. Pipet 1 mL of the sample solution, and add methanol to make exactly 50 mL. Pipet 5 mL of this ble in diethyl ether. A solution of Bufetolol Hydrochloride (1 in 10) shows no optical rotation. Identification (1) To 5 mL of a solution of Bufetolol Hydrochloride (1 in 100) add 5 drops of Reinecke salt TS: a light red precipitate is formed. Determine the absorption spectrum of a solution of Bufetolol Hydrochloride (1 in 20,000) as directed under Ul-traviolet-visible Spectrophotometry <2.24>, and compare the spectrum with the Reference Spectrum: both spectra exhibit similar intensities of absorption at the same wavelengths. Determine the infrared absorption spectrum of Bufetolol Hydrochloride, previously dried, as directed in the potassium chloride disk method under Infrared Spectropho- JP XVIII Official Monographs / Buformin Hydrochloride 573 tometry <2.25>, and compare the spectrum with the Refer-ence Spectrum: both spectra exhibit similar intensities of ab-sorption at the same wave numbers. ‌A solution of Bufetolol Hydrochloride (1 in 50) re-sponds to Qualitative Tests <1.09> for chloride. Melting point <2.60> 153 – 1579C Purity (1) Clarity and color of solution—Dissolve 1.0 g of Bufetolol Hydrochloride in 10 mL of water: the solution is clear and colorless. Sulfate <1.14>—Perform the test with 0.5 g of Bufetolol Hydrochloride. Prepare the control solution with 0.40 mL of 0.005 mol/L sulfuric acid VS (not more than 0.038z). Heavy metals <1.07>—Proceed with 2.0 g of Bufetolol Hydrochloride according to Method 2, and per-form the test. Prepare the control solution with 2.0 mL of Standard Lead Solution (not more than 10 ppm). Related substances—Dissolve 0.20 g of Bufetolol Hy-drochloride in 5 mL of methanol, and use this solution as the sample solution. Pipet 1 mL of the sample solution, add methanol to make exactly 200 mL, and use this solution as the standard solution. Perform the test with these solutions as directed under Thin-layer Chromatography <2.03>. Spot 10 mL each of the sample solution and standard solution on a plate of silica gel with fluorescent indicator for thin-layer chromatography. Develop the plate with a mixture of chlo-roform, acetone, ethanol (95) and ammonia solution (28) (40:20:5:1) to a distance of about 10 cm, and air-dry the plate. Examine under ultraviolet light (main wavelength: 254 nm): the spots other than the principal spot obtained from the sample solution are not more intense than the spot from the standard solution. Loss on drying <2.41> Not more than 0.5z (1 g, 1059C, 4 hours). Residue on ignition <2.44> Not more than 0.1z (1 g)."
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Weigh accurately about 0.4 g of Bufetolol Hydro-chloride, previously dried, dissolve in 10 mL of acetic acid (100), add 50 mL of acetic anhydride, and titrate <2.50> with 0.1 mol/L perchloric acid VS (potentiometric titration). Per-form a blank determination in the same manner, and make any necessary correction. Each mL of 0.1 mol/L perchloric acid VS ＝ 35.99 mg of C18H29NO4.HCl"
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Tight containers."
  }
}