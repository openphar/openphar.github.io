{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/chemicals/emorfazone",
  "@type": "ChemicalDrugMonograph",
  "prefLabel": {
    "en": "Emorfazone",
    "ja": "エモルファゾン"
  },
  "monographId": "JP18-emorfazone",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "molecularFormula": "C11H17N3O3",
  "molecularWeight": 239.27,
  "casNumber": "38957-41-4",
  "definition": {
    "en": "Emorfazone, when dried, contains not less than 98."
  },
  "appearance": {
    "en": "Emorfazone occurs as colorless crystals or a white to light yellow crystalline powder. It is very soluble in ethanol (99.5), and freely soluble in water and in acetic anhydride. It dissolves in 1 mol/L hydrochloric acid TS. It gradually turns yellow and decomposes on exposure to light."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "(1) Dissolve 20 mg of Emorfazone in 2 mL of 1 mol/L hydrochloric acid TS, and add 5 drops of Reinecke's TS: light red floating matters are formed. Determine the absorption spectrum of a solution of Emorfazone (1 in 100,000) as directed under Ultraviolet-visible Spectrophotometry <2.24>, and compare the spectrum with the Reference Spectrum: both spectra exhibit similar in-tensities of absorption at the same wavelengths. Determine the infrared absorption spectrum of Emorfazone as directed in the potassium bromide disk method under Infrared Spectrophotometry <2.25>, and com-pare the spectrum with the Reference Spectrum: both spectra exhibit similar intensities of absorption at the same wave numbers."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Chloride <1.03>—Perform the test with 1.0 g of Emorfazone. Prepare the control solution with 0.50 mL of 0.01 mol/L hydrochloric acid VS (not more than 0.018z). (2) Heavy metals <1.07>—Proceed with 2.0 g of Emorfa-zone according to Method 2, and perform the test. Prepare the control solution with 2.0 mL of Standard Lead Solution (not more than 10 ppm)."
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Weigh accurately about 0.2 g of Emorfazone, previ-ously dried, dissolve in 60 mL of acetic anhydride, and titrate <2.50> with 0.1 mol/L perchloric acid VS (potentio-metric titration). Perform a blank determination in the same manner, and make any necessary correction. Each mL of 0.1 mol/L perchloric acid VS ＝ 23.93 mg of C H N O 11 17 3 3 Purity (1) Chloride <1.03>—Perform the test with 1.0 g of Emorfazone. Prepare the control solution with 0.50 mL of 0.01 mol/L hydrochloric acid VS (not more than 0.018z). (2) Heavy metals <1.07>—Proceed with 2.0 g of Emorfa-zone according to Method 2, and perform the test. Prepare the control solution with 2.0 mL of Standard Lead Solution (not more than 10 ppm)."
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Tight containers. Storage—Light-resistant."
  }
}