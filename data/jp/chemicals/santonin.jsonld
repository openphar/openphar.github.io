{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/chemicals/santonin",
  "@type": "ChemicalDrugMonograph",
  "prefLabel": {
    "en": "Santonin",
    "ja": "サントニン"
  },
  "monographId": "JP18-santonin",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "molecularFormula": "C15H18O3",
  "molecularWeight": 246.3,
  "definition": {
    "en": "Santonin, when dried, contains not less than 98."
  },
  "appearance": {
    "en": "Santonin occurs as colorless crystals, or a white crystalline powder. It is freely soluble in chloroform, sparingly soluble in ethanol (95), and practically insoluble in water. It becomes yellow by light."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "(1) Determine the absorption spectrum of a solution of Santonin in ethanol (95) (3 in 250,000) as directed under Ultraviolet-visible Spectrophotometry <2.24>, and compare the spectrum with the Reference Spectrum: both spectra exhibit similar intensities of absorption at the same wavelengths. (2) Determine the infrared absorption spectrum of San-tonin as directed in the potassium bromide disk method under Infrared Spectrophotometry <2.25>, and compare the spectrum with the Reference Spectrum: both spectra exhibit similar intensities of absorption at the same wave numbers. D Optical rotation <2.49> [a]20: －170 – －1759(0.2 g, chlo-roform, 10 mL, 100 mm)."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Heavy metals <1.07>—Proceed with 1.0 g of Santonin according to Method 4, and perform the test. Pre-pare the control solution with 2.0 mL of Standard Lead So-lution (not more than 20 ppm). Alkaloids—Boil 0.5 g of Santonin with 20 mL of di-luted sulfuric acid (1 in 100), cool, and filter. Dilute 10 mL of the filtrate with water to 30 mL, add 3 drops of iodine TS, and allow to stand for 3 hours: no turbidity is produced. Artemisin—Dissolve 1.0 g of powdered Santonin in 2 mL of chloroform by slight warming: the solution is clear and colorless, or any yellow color produced is not darker than Matching Fluid A. Phenols—Boil 0.20 g of Santonin with 10 mL of water, cool, and filter. To the filtrate add bromine TS until the color of the solution becomes yellow: no turbidity is pro-duced. Acid-coloring substances—Moisten 10 mg of Santo-nin with nitric acid: no color develops immediately. Moisten Santonin with sulfuric acid, previously cooled to 09C: no color is produced immediately. Loss on drying <2.41> Not more than 0.5z (1 g, 1059C, 3 hours). Residue on ignition <2.44> Not more than 0.2z (1 g)."
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Weigh accurately about 0.25 g of Santonin, previ- ously dried, dissolve in 10 mL of ethanol (95) by warming, add exactly 20 mL of 0.1 mol/L sodium hydroxide VS, and heat on a water bath under a reflux condenser for 5 minutes. Cool quickly, and titrate <2.50> the excess sodium hydroxide with 0.05 mol/L hydrochloric acid VS (indicator: 3 drops of phenolphthalein TS). Perform a blank determination in the same manner. Each mL of 0.1 mol/L sodium hydroxide VS ＝ 24.63 mg of C15H18O3"
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Tight containers. Storage—Light-resistant."
  }
}