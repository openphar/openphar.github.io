{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/crude-drugs/angelicae-dahuricae-radix",
  "@type": "CrudeDrugMonograph",
  "prefLabel": {
    "en": "Angelicae Dahuricae Radix",
    "ja": "ビャクシ"
  },
  "monographId": "JP18-angelicae-dahuricae-radix",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "appearance": {
    "en": "Main root from which many long roots are branched out and nearly fusiform and conical in whole shape, 10 – 25 cm in length; externally grayish brown to dark brown, with longitudinal wrinkles, and with numerous scars of rootlets laterally elongated and protruded. A few remains of leaf sheath at the crown and ring-nodes closely protruded near the crown. In a transverse section, the outer region is grayish white in color, and the central region is sometimes dark brown in color. Odor, characteristic; taste, slightly bitter."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "To 0.2 g of pulverized Angelica Dahurica Root add 5 mL of ethanol (95), shake for 5 minutes, and filter. Examine the filtrate under ultraviolet light (main wavelength: 365 nm): a blue to blue-purple fluorescence develops."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Heavy metals <1.07>—Proceed with 3.0 g of pulverized Angelica Dahurica Root according to Method 3, and perform the test. Prepare the control solution with 3.0 mL of Standard Lead Solution (not more than 10 ppm). Arsenic <1.11>—Prepare the test solution with 0.40 g of pulverized Angelica Dahurica Root according to Method 4, and perform the test (not more than 5 ppm). Leaf sheath—When perform the test of foreign mat-ter <5.01>, the amount of leaf sheath contained in Angelica Dahurica Root does not exceed 3.0z. Foreign matter <5.01>—The amount of foreign mat-ter other than leaf sheath contained in Angelica Dahurica Root is not more than 1.0z. Total ash <5.01> Not more than 7.0z. Acid-insoluble ash <5.01> Not more than 2.0z. Extract content <5.01> Dilute ethanol-soluble extract: not less than 25.0z."
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Well-closed contain-ers."
  }
}