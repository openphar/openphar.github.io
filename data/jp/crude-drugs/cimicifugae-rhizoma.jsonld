{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/crude-drugs/cimicifugae-rhizoma",
  "@type": "CrudeDrugMonograph",
  "prefLabel": {
    "en": "Cimicifugae Rhizoma",
    "ja": "ショウマ"
  },
  "monographId": "JP18-cimicifugae-rhizoma",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "appearance": {
    "en": "Knotted, irregularly shaped rhizome, 6 – 18 cm in length, 1 – 2.5 cm in diameter; externally dark brown to blackish brown, with many remains of roots, often with scars of terrestrial stems; the center of the scar dented, and the circumference being pale in color and showing a radial pattern; fractured surface fibrous; pith dark brown in color and often hollow; light and hard in texture. Almost odorless; taste, bitter and slightly astringent."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "Dissolve 1 g of pulverized Cimicifuga Rhi-zome add 5 mL of dilute hydrochloric acid and 5 mL of diethyl ether, shake for 10 minutes, centrifuge, and use the diethy ether layer as the sample solution. Use (E)-isoferulic acid-(E)-ferulic acid TS for thin-layer chromatography as the standard solution. Perform the test with these solutions as directed under Thin-layer Chromatography <2.03>. Spot 10 mL of the sample solution and 2 mL of the standard solution on a plate of silica gel for thin-layer chromatography. De-velop the plate with a mixture of ethyl acetate, hexane and acetic acid (100) (30:10:1) to a distance of about 7 cm, and air-dry the plate. Examine under ultraviolet light (main wavelength: 365 nm): one of the spot among the several spots obtained from the sample solution has the same color tone and Rf value with the blue fluorescent spot from the standard solution."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Heavy metals <1.07>—Proceed with 3.0 g of pulverized Cimicifuga Rhizome according to Method 3, and ‌JP XVIII Crude Drugs and Related Drugs / Powdered Cinnamon Bark 1981‌ perform the test. Prepare the control solution with 3.0 mL of Standard Lead Solution (not more than 10 ppm). Arsenic <1.11>—Prepare the test solution with 0.40 g of pulverized Cimicifuga Rhizome according to Method 4, and perform the test (not more than 5 ppm). Rhizome of Astilbe thunbergii Miquel—Under a microscope <5.01>, pulverized Cimicifuga Rhizome does not contain crystal druses in the parenchyma. Total ash <5.01> Not more than 9.0z. Acid-insoluble ash <5.01> Not more than 1.5z. Extract content <5.01> Dilute ethanol-soluble extract: not less than 18.0z."
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Well-closed contain-ers."
  }
}