{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/crude-drugs/oleum-eucalypti",
  "@type": "CrudeDrugMonograph",
  "prefLabel": {
    "en": "Oleum Eucalypti",
    "ja": "ユーカリ油"
  },
  "monographId": "JP18-oleum-eucalypti",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "appearance": {
    "en": "Eucalyptus Oil is a clear, colorless or pale yel-low liquid. It has a characteristic, aromatic odor and a pun-gent taste. It is neutral."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "Shake 1 mL of Eucalyptus Oil vigorously with 1 mL of phosphoric acid, and allow to stand: the solu-tion congeals within 30 minutes. D Refractive index <2.45> n20: 1.458 – 1.470 Specific gravity <1.13> d 20: 0.907 – 0.927"
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Clarity of solution—Mix 1.0 mL of Eucalyptus Oil with 5 mL of diluted ethanol (7 in 10): the solution is clear. (2) Heavy metals <1.07>—Proceed with 1.0 mL of Eu- calyptus Oil according to Method 2, and perform the test. Prepare the control solution with 4.0 mL of Standard Lead Solution (not more than 40 ppm)."
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Weigh accurately about 0.1 g each of Eucalyptus Oil and cineol for assay, and dissolve each in hexane to make ex-actly 25 mL. Pipet 5 mL each of these solutions, add exactly 5 mL of the internal standard solution to each, then add hexane to make 100 mL, and use these solutions as the sam-ple solution and the standard solution, respectively. Perform the test with 2 mL each of the sample solution and standard solution as directed under Gas Chromatography <2.02> according to the following conditions. Calculate the ratios, QT and QS, of the peak area of cineol to that of the internal standard. Amount (mg) of cineol ＝ MS × QT/QS MS: Amount (mg) of cineol for assay taken Internal standard solution—A solution of anisole in hexane (1 in 250). Operating conditions— Detector: A hydrogen ‰ame-ionization detector. Column: A glass column 3 mm in inside diameter and 5 m in length, packed with silanized porous silica gel for gas chromatography coated in 5z with alkylene glycol phthalate ester for gas chromatography (150 to 180 mm in particle di-ameter). Column temperature: A constant temperature of about 1209C. Carrier gas: Nitrogen. Flow rate: Adjust so that the retention time of cineol is about 11 minutes. System suitability— System performance: Dissolve 0.1 g each of cineol for as-say and limonene in 25 mL of hexane. To 1 mL of this solu-tion add hexane to make 20 mL. When the procedure is run with 2 mL of this solution under the above operating condi-tions, limonene and cineol are eluted in this order with the resolution between these peaks being not less than 1.5. System repeatability: When the test is repeated 6 times with 2 mL of the standard solution under the above operating conditions, the relative standard deviation of the ratio of the peak area of cineol to that of the internal standard is not more than 1.0z."
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Tight containers. Storage—Light-resistant."
  }
}