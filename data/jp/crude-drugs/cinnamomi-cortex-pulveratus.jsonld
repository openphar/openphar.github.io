{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/crude-drugs/cinnamomi-cortex-pulveratus",
  "@type": "CrudeDrugMonograph",
  "prefLabel": {
    "en": "Cinnamomi Cortex Pulveratus",
    "ja": "ケイヒ末"
  },
  "monographId": "JP18-cinnamomi-cortex-pulveratus",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "appearance": {
    "en": "Powdered Cinnamon Bark is red-brown to brown in color. It has a characteristic aroma and a sweet, pungent taste with a slightly mucilaginous and astringent aftertaste. Under a microscope <5.01>, Powdered Cinnamon Bark re- veals starch grains, fragments of parenchyma cells contain-ing them; fragments of fibers, oil cells containing yellow-brown oil droplets, stone cells, cork stone cells, cork tissue, and fine crystals of calcium oxalate. Starch grains are simple and compound grains 6 to 20 mm in diameter."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "To 2.0 g of Powdered Cinnamon Bark add 10 mL of diethyl ether, shake for 3 minutes, filter, and use the filtrate as the sample solution. Perform the test with this solution as directed under Thin-layer Chromatography <2.03>. Spot 10 mL of the sample solution on a plate of silica gel with fluorescent indicator for thin-layer chromatogra-phy. Develop the plate with a mixture of hexane and ethyl acetate (2:1) to a distance of about 7 cm, and air-dry the plate. Examine under ultraviolet light (main wavelength: 254 nm): a purple spot develops at an Rf value of about 0.4. Spray 2,4-dinitrophenylhydrazine TS upon the spot: a yellow orange color develops."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Petiole—Under a microscope <5.01>, Pow-dered Cinnamon Bark does not reveal epidermal cells, hairs, cells containing chlorophyll granules, and fragments of vas-cular bundle. (2) Total BHC's and total DDT's <5.01>—Not more than 0.2 ppm, respectively. Loss on drying <5.01> Not more than 15.0z (6 hours). Total ash <5.01> Not more than 6.0z. Essential oil content <5.01> Perform the test with 50.0 g of Powdered Cinnamon Bark provided that 1 mL of silicon resin is previously added to the sample in the flask: the volume of essential oil is not less than 0.35 mL."
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Tight containers."
  }
}