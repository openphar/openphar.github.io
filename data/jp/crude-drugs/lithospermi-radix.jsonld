{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/crude-drugs/lithospermi-radix",
  "@type": "CrudeDrugMonograph",
  "prefLabel": {
    "en": "Lithospermi Radix",
    "ja": "シコン"
  },
  "monographId": "JP18-lithospermi-radix",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "appearance": {
    "en": "Rather slender conical root, often branched, 6 – 10 cm in length, 0.5 – 1.5 cm in diameter; externally dark purple, coarse in texture, thin and easily peeled; mostly with twisted and deep longitudinal furrows, which sometimes reach to xylem; sometimes remains of stem at the crown; easily broken; fractured surface granular and with many clefts. Under a magnifying glass, a transverse section reveals a dark purple color at the outer portion of cortex, and light brown inner portion making irregular wave; xylem yellowish in color; the center of the crown is often cracked, and the surrounding part red-purple. Odor, slight; taste, slightly sweet."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "(1) Heat 0.5 g of pulverized Lithospermum Root in a test tube: red vapor evolves, which condenses on the wall of the upper part of the tube into red-brown oil drops. Shake 0.5 g of pieces or powder of Lithospermum Root with 1 mL of ethanol (95), and to the red solution thereby obtained add 1 drop of sodium hydroxide TS: the red color changes to blue-purple. To this solution add 1 to 2 drops of dilute hydrochloric acid: the color turns red again. To 0.5 g of pulverized Lithospermum Root add 5 mL of ethanol (95), shake for 30 minutes, filter, and evaporate the solvent of the filtrate at a temperature not higher than 409C under low pressure (in vacuo). Add 1 mL of ethanol (95) to the residue, and use this solution as the sample solu-tion. Perform the test with the sample solution as directed under Thin-layer Chromatography <2.03>. Spot 5 mL of the sample solution on a plate of silica gel for thin-layer chroma-tography. Develop the plate with a mixture of ethyl acetate and ethanol (95) (3:1) to a distance of about 7 cm, and air-dry the plate: a red-purple spot appears at an Rf value of about 0.75."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Heavy metals <1.07>—Proceed with 2.0 g of pulverized Lithospermum Root according to Method 3, and perform the test. Prepare the control solution with 3.0 mL of Standard Lead Solution (not more than 15 ppm). (2) Arsenic <1.11>—Prepare the test solution with 0.40 g of pulverized Lithospermum Root according to Method 4, and perform the test (not more than 5 ppm). Total ash <5.01> Not more than 11.0z. Acid-insoluble ash <5.01> Not more than 3.5z."
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Well-closed contain-ers."
  }
}