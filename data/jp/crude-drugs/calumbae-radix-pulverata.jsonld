{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/crude-drugs/calumbae-radix-pulverata",
  "@type": "CrudeDrugMonograph",
  "prefLabel": {
    "en": "Calumbae Radix Pulverata",
    "ja": "コロンボ末"
  },
  "monographId": "JP18-calumbae-radix-pulverata",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "appearance": {
    "en": "Powdered Calumba occurs as a grayish yellow powder, and has a characteristic odor and a bitter taste. Under a microscope <5.01>, Powdered Calumba reveals numerous starch grains, fragments of parenchyma cells con-taining them; fragments of cork cells, stone cells, fibers, sub-stitute fibers, vessels, tracheids, and also solitary crystals of calcium oxalate; starch grains consisting of solitary grains or 2- to 3-compound grains; hilum, unevenly scattered, usually 25 – 50 mm, but up to 90 mm in diameter."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "To 3 g of Powdered Calumba add 30 mL of water, allow to stand for 5 minutes with occasional shaking, and filter. To 2 mL of the filtrate add gently 1 mL of sulfuric acid, and after cooling, add carefully chlorine TS to make two layers: a light red to red color develops at the zone of contact."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Heavy metals <1.07>—Proceed with 2.0 g of Powdered Calumba according to Method 3, and perform the test. Prepare the control solution with 3.0 mL of Standard Lead Solution (not more than 15 ppm). (2) Arsenic <1.11>—Prepare the test solution with 0.40 g of Powdered Calumba according to Method 4, and perform the test (not more than 5 ppm). Total ash <5.01> Not more than 7.5z."
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Well-closed contain-ers."
  }
}