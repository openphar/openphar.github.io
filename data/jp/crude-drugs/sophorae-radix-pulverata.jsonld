{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/crude-drugs/sophorae-radix-pulverata",
  "@type": "CrudeDrugMonograph",
  "prefLabel": {
    "en": "Sophorae Radix Pulverata",
    "ja": "クジン末"
  },
  "monographId": "JP18-sophorae-radix-pulverata",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "appearance": {
    "en": "Powdered Sophora Root occurs as a light brown powder. It has a slight odor, and an extremely bitter and lasting taste. Under a microscope <5.01>, Powdered Sophora Root re- veals mainly starch grains and fragments of parenchyma ‌2156‌‌ Soybean Oil / Crude Drugs and Related Drugs cells containing them, fibers, bordered pitted vessels, reticu-late vessels; a few fragments of corky tissue and solitary crystals of calcium oxalate. Starch grains usually composed of 2- to 4-compound grains 15 – 20 mm in diameter, and sim-ple grains 2 – 5 mm in diameter."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "To 1.0 g of Powdered Sophora Root add 10 mL of methanol, shake for 10 minutes, filter, and use the fil-trate as the sample solution. Perform the test with the sam-ple solution as directed under Thin-layer Chromatography <2.03>. Spot 1 mL of the sample solution on a plate of silica gel for thin-layer chromatography, develop the plate with a mixture of ethanol (99.5), ethyl acetate, and ammonia solu-tion (28) (3:2:1) to a distance of about 7 cm, and air-dry the plate. Spray evenly Dragendorff's TS for spraying on the plate, and air-dry the plate. Then spray evenly sodium nitrite TS on the plate: two brown spots appear at an Rf value of about 0.5."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Heavy metals <1.07>—Proceed with 3.0 g of Powdered Sophora Root according to Method 3, and per-form the test. Prepare the control solution with 3.0 mL of Standard Lead Solution (not more than 10 ppm). (2) Arsenic <1.11>—Prepare the test solution with 0.40 g of Powdered Sophora Root according to Method 4, and perform the test (not more than 5 ppm). Total ash <5.01> Not more than 6.0z. Acid-insoluble ash <5.01> Not more than 1.5z."
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Well-closed contain-ers."
  }
}