{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/crude-drugs/sophorae-radix",
  "@type": "CrudeDrugMonograph",
  "prefLabel": {
    "en": "Sophorae Radix",
    "ja": "クジン"
  },
  "monographId": "JP18-sophorae-radix",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "appearance": {
    "en": "Cylindrical root, 5 – 20 cm in length, 2 – 3 cm in diameter; externally dark brown to yellow-brown, with distinct longitudinal wrinkles, and with laterally extended lenticels; root without periderm, externally yellow-white, with somewhat fibrous surface; under a magnifying glass, the transverse section, light yellow-brown; cortex, 0.1 – 0.2 cm in thickness, slightly tinged with dark color near cambi-um, forming a crack between xylem. Odor, slight; taste, extremely bitter and lasting."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "To 1.0 g of pulverized Sophora Root add 10 mL of methanol, shake for 10 minutes, filter, and use the fil-trate as the sample solution. Perform the test with the sam-ple solution as directed under Thin-layer Chromatography <2.03>. Spot 1 mL of the sample solution on a plate of silica gel for thin-layer chromatography, develop the plate with a mixture of ethanol (99.5), ethyl acetate and ammonia solu-tion (28) (3:2:1) to a distance of about 7 cm, and air-dry the plate. Spray evenly Dragendorff's TS for spraying on the plate, and air-dry the plate. Then spray evenly sodium nitrite TS on the plate: two brown spots appear at an Rf value of about 0.5."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Heavy metals <1.07>—Proceed with 3.0 g of pulverized Sophora Root according to Method 3, and per-form the test. Prepare the control solution with 3.0 mL of Standard Lead Solution (not more than 10 ppm). Arsenic <1.11>—Prepare the test solution with 0.40 g of pulverized Sophora Root according to Method 4, and per-form the test (not more than 5 ppm). Stem—When perform the test of foreign matter <5.01>, the amount of its stems contained in Sophora Root does not exceed 10.0z. Foreign matter <5.01>—The amount of foreign mat-ter other than stems is not more than 1.0z. Total ash <5.01> Not more than 6.0z. Acid-insoluble ash <5.01> Not more than 1.5z."
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Well-closed contain-ers."
  }
}