  "definition": {
    "en": "Freeze-dried Live Attenuated Measles Vaccine is a preparation for injection which is dissolved before use. It contains live attenuated measles virus."
  },
  "appearance": {
    "en": "Freeze-dried Live Attenuated Measles Vaccine becomes a colorless, yellowish or reddish clear liquid on ad-dition of solvent. Meclofenoxate Hydrochloride"
  }
