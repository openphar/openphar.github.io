{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/minerals/magnesium-sulfate-hydrate",
  "@type": "MineralSubstanceMonograph",
  "prefLabel": {
    "en": "‌Magnesium Sulfate Hydrate‌",
    "ja": "硫酸マグネシウム水和物"
  },
  "monographId": "JP18-magnesium-sulfate-hydrate",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "appearance": {
    "en": "Magnesium Sulfate Hydrate occurs as color-less or white crystals. It has a cooling, saline, bitter taste. It is very soluble in water, and practically insoluble in ethanol (95). It dissolves in dilute hydrochloric acid."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "A solution of Magnesium Sulfate Hydrate (1 in 40) responds to Qualitative Tests <1.09> for magnesium salt and for sulfate. pH <2.54> Dissolve 1.0 g of Magnesium Sulfate Hydrate in 20 mL of water: the pH of this solution is between 5.0 and 8.2."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Clarity and color of solution—Dissolve 1.0 g of Magnesium Sulfate Hydrate in 20 mL of water: the solu-tion is clear and colorless. Chloride <1.03>—Perform the test with 1.0 g of Mag- nesium Sulfate Hydrate. Prepare the control solution with 0.40 mL of 0.01 mol/L hydrochloric acid VS (not more than 0.014z). Heavy metals <1.07>—Proceed with 2.0 g of Magnesi- um Sulfate Hydrate according to Method 1, and perform the test. Prepare the control solution with 2.0 mL of Standard Lead Solution (not more than 10 ppm). Zinc—Dissolve 2.0 g of Magnesium Sulfate Hydrate in 20 mL of water, and add 1 mL of acetic acid (31) and 5 drops of potassium hexacyanoferrate (II) TS: no turbidity is produced. Calcium—Dissolve 1.0 g of Magnesium Sulfate Hy-drate in 5.0 mL of dilute hydrochloric acid, add water to make 100 mL, and use this solution as the sample solution. Separately, dissolve 1.0 g of Magnesium Sulfate Hydrate in 2.0 mL of Standard Calcium Solution and 5.0 mL of dilute hydrochloric acid, add water to make exactly 100 mL, and use this solution as the standard solution. Perform the test with the sample solution and standard solution as directed under Atomic Absorption Spectrophotometry <2.23> accord-ing to the following conditions, and determine the absor-bances, AT and AS, of both solutions: AT is smaller than AS － AT (not more than 0.02z). Gas: Combustible gas—Acetylene or hydrogen. Supporting gas—Air. Lamp: Calcium hollow-cathod lamp. Wavelength: 422.7 nm. Arsenic <1.11>—Prepare the test solution with 1.0 g <2.50> with 0.05 mol/L disodium dihydrogen ethylene-diamine tetraacetate VS (indicator: 40 mg of eriochrome black T-sodium chloride indicator). Perform a blank deter-mination in the same manner, and make any necessary cor-rection. Each mL of 0.05 mol/L disodium dihydrogen ethylenediamine tetraacetate VS ＝ 6.018 mg of MgSO4"
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Well-closed contain-ers."
  }
}