{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/minerals/sodium-citrate-hydrate",
  "@type": "MineralSubstanceMonograph",
  "prefLabel": {
    "en": "Sodium Citrate Hydrate",
    "ja": "クエン酸ナトリウム水和物"
  },
  "monographId": "JP18-sodium-citrate-hydrate",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "definition": {
    "en": "Sodium Citrate Hydrate, when dried, contains not less than 99."
  },
  "appearance": {
    "en": "Sodium Citrate Hydrate occurs as colorless crystals, or a white crystalline powder. It is odorless, and has a cooling, saline taste. It is freely soluble in water, and practically insoluble in ethanol (95) and in diethyl ether."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "A solution of Sodium Citrate Hydrate (1 in 20) responds to Qualitative Tests <1.09> for citrate and for sodium salt. pH <2.54> Dissolve 1.0 g of Sodium Citrate Hydrate in 20 mL of water: the pH of this solution is between 7.5 and 8.5."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Clarity and color of solution—A solution of 1.0 g of Sodium Citrate Hydrate in 10 mL of water is clear and colorless. Chloride <1.03>—Take 0.6 g of Sodium Citrate Hy- drate, and perform the test. Prepare the control solution with 0.25 mL of 0.01 mol/L hydrochloric acid VS (not more than 0.015z). Sulfate <1.14>—To 0.5 g of Sodium Citrate Hydrate add water to make 40 mL, then add 3.0 mL of dilute hydro-chloric acid and water to make 50 mL, and perform the test. Prepare the control solution with 0.50 mL of 0.005 mol/L sulfuric acid VS (not more than 0.048z). Heavy metals <1.07>—Proceed with 2.5 g of Sodium Citrate Hydrate according to Method 2, and perform the test. Prepare the control solution with 2.5 mL of Standard Lead Solution (not more than 10 ppm). Arsenic <1.11>—Prepare the test solution with 1.0 g of Sodium Citrate Hydrate according to Method 1, and per-form the test (not more than 2 ppm). Tartrate—To a solution of 1.0 g of Sodium Citrate Hydrate in 2 mL of water add 1 mL of potassium acetate TS and 1 mL of acetic acid (31): no crystalline precipitate is formed after the sides of the tube have been rubbed with a glass rod. Oxalate—Dissolve 1.0 g of Sodium Citrate Hydrate in a mixture of 1 mL of water and 3 mL of dilute hydrochlo-ric acid, add 4 mL of ethanol (95) and 0.2 mL of calcium chloride TS, and allow to stand for 1 hour: the solution is clear. Readily carbonizable substances <1.15>—Take 0.5 g of Sodium Citrate Hydrate, and perform the test by heating at 909C for 1 hour: the solution has no more color than Matching Fluid K. Loss on drying <2.41> 10.0 – 13.0z (1 g, 1809C, 2 hours)."
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Weigh accurately about 0.2 g of Sodium Citrate Hy-drate, previously dried, add 30 mL of acetic acid for nona-queous titration, warm to dissolve, and titrate <2.50> with 0.1 mol/L perchloric acid VS (potentiometric titration). Per-form a blank determination in the same manner, and make any necessary correction. Each mL of 0.1 mol/L perchloric acid VS ＝ 8.602 mg of C6H5Na3O7"
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Tight containers."
  }
}