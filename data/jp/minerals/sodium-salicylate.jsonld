{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/minerals/sodium-salicylate",
  "@type": "MineralSubstanceMonograph",
  "prefLabel": {
    "en": "Sodium Salicylate",
    "ja": "サリチル酸ナトリウム"
  },
  "monographId": "JP18-sodium-salicylate",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "definition": {
    "en": "Sodium Salicylate, when dried, contains not less than 99."
  },
  "appearance": {
    "en": "Sodium Salicylate occurs as white, crystals or crystalline powder. It is very soluble in water, freely soluble in acetic acid (100), and soluble in ethanol (95). It is gradually colored by light."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "(1) Determine the infrared absorption spec-trum of Sodium Salicylate, previously dried, as directed in the potassium bromide disk method under Infrared Spectro-photometry <2.25>, and compare the spectrum with the Ref-erence Spectrum: both spectra exhibit similar intensities of absorption at the same wave numbers. A solution of Sodium Salicylate (1 in 20) responds to Qualitative Tests <1.09> for sodium salt. pH <2.54> The pH of a solution of 2.0 g of Sodium Salicy-late in 20 mL of water is between 6.0 and 8.0."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Clarity and color of solution—Dissolve 1.0 g of Sodium Salicylate in 10 mL of water: the solution is clear, and its absorbance at 420 nm determined as directed under Ultraviolet-visible Spectrophotometry <2.24> is not more than 0.02. Chloride <1.03>—Dissolve 0.5 g of Sodium Salicylate in 15 mL of water, add 6 mL of dilute nitric acid and ethanol (95) to make 50 mL, and perform the test using this solution as the test solution. Prepare the control solution with 0.30 mL of 0.01 mol/L hydrochloric acid VS, 28 mL of ethanol (95), 6 mL of dilute nitric acid and water to make 50 mL (not more than 0.021z). Sulfate—Dissolve 0.25 g of Sodium Salicylate in 5 mL of water, and add 0.5 mL of barium chloride TS: the solution shows no change. Sulfite and thiosulfate—Dissolve 1.0 g of Sodium Salicylate in 20 mL of water, add 1 mL of hydrochloric acid, and filter. Add 0.15 mL of 0.05 mol/L iodine VS to the fil-trate: a yellow color develops. Heavy metals <1.07>—Proceed with 1.0 g of Sodium Salicylate according to Method 2, and perform the test. Pre-pare the control solution with 2.0 mL of Standard Lead So-lution (not more than 20 ppm). Arsenic <1.11>—To 1.0 g of Sodium Salicylate in a decomposition flask add 5 mL of nitric acid and 2 mL of sul-furic acid, and heat carefully until white fumes are evolved. After cooling, add 2 mL of nitric acid, and heat. After cool-ing, add several 2-mL portions of hydrogen peroxide (30), and heat until the solution is colorless to pale yellow. Repeat the procedure of adding nitric acid and hydrogen peroxide (30) and heating, if necessary. After cooling, add 2 mL of a saturated solution of ammonium oxalate monohydrate, and heat until white fumes are evolved. After cooling, add water to make 5 mL, and perform the test with this solution (not more than 2 ppm). Loss on drying <2.41> Not more than 0.5z (1 g, 1059C, 2 hours)."
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Weigh accurately about 0.3 g of Sodium Salicylate, previously dried, dissolve in 50 mL of acetic acid (100), and titrate <2.50> with 0.1 mol/L perchloric acid VS (potenti-ometric titration). Perform a blank determination in the same manner, and make any necessary correction. Each mL of 0.1 mol/L perchloric acid VS ＝ 16.01 mg of C7H5NaO3"
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Tight containers. Storage—Light-resistant."
  }
}