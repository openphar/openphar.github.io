{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/minerals/dibasic-sodium-phosphate-hydrate",
  "@type": "MineralSubstanceMonograph",
  "prefLabel": {
    "en": "Dibasic Sodium Phosphate Hydrate",
    "ja": "リン酸水素ナトリウム水和物"
  },
  "monographId": "JP18-dibasic-sodium-phosphate-hydrate",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "definition": {
    "en": "Dibasic Sodium Phosphate Hydrate contains not less than 98."
  },
  "appearance": {
    "en": "Dibasic Sodium Phosphate Hydrate occurs as colorless or white crystals. It is odorless. It is freely soluble in water, and practically insoluble in ethanol (95) and in diethyl ether. It effloresces in warm, dry air."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "(1) A solution of Dibasic Sodium Phos-phate Hydrate (1 in 10) responds to Qualitative Tests <1.09> (1) and (2) for sodium salt. A solution of Dibasic Sodium Phosphate Hydrate (1 in 10) responds to Qualitative Tests <1.09> (1) and (3) for phosphate. Dissolve 0.1 g of Dibasic Sodium Phosphate Hydrate in 5 mL of dilute nitric acid, warm at 709C for 1 to 2 minutes, and add 2 mL of hexaammonium heptamolybdate TS: a yellow precipitate is formed. pH <2.54> Dissolve 1.0 g of Dibasic Sodium Phosphate Hydrate in 50 mL of water: the pH of this solution is be-tween 9.0 and 9.4."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Clarity and color of solution—Dissolve 1.0 g of Dibasic Sodium Phosphate Hydrate in 20 mL of water: the solution is clear and colorless. Chloride <1.03>—Dissolve 1.0 g of Dibasic Sodium Phosphate Hydrate in 7 mL of dilute nitric acid and water to make 50 mL. Perform the test using this solution as the test solution. Prepare the control solution with 0.40 mL of 0.01 mol/L hydrochloric acid VS (not more than 0.014z). Sulfate <1.14>—Dissolve 0.5 g of Dibasic Sodium Phosphate Hydrate in 2 mL of dilute hydrochloric acid and water to make 50 mL. Perform the test using this solution as the test solution. Prepare the control solution with 0.40 mL of 0.005 mol/L sulfuric acid VS (not more than 0.038z). Carbonate—To 2.0 g of Dibasic Sodium Phosphate Hydrate add 5 mL of water, boil, and add 2 mL of hydro-chloric acid after cooling: the solution does not effervesce. Heavy metals <1.07>—Dissolve 2.0 g of Dibasic So- ‌dium Phosphate Hydrate in 4 mL of acetic acid (31) and water to make 50 mL. Perform the test using this solution as the test solution. Prepare the control solution with 2.0 mL of Standard Lead Solution by adding 2 mL of dilute acetic acid and water to make 50 mL (not more than 10 ppm). Arsenic <1.11>—Prepare the test solution with 1.0 g of Dibasic Sodium Phosphate Hydrate according to Method vacuum for 4 hours, as directed in the potassium bromide disk method under Infrared Spectrophotometry <2.25>, and compare the spectrum with the Reference Spectrum: both spectra exhibit similar intensities of absorption at the same wave numbers. A solution of Sodium Picosulfate Hydrate (1 in 10) responds to Qualitative Tests <1.09> for sodium salt. 1 cm 1, and perform the test (not more than 2 ppm). Absorbance <2.24> E1z (263 nm): 120 – 130 (4 mg calcu- Loss on drying <2.41> 57.0 – 61.0z (1 g, at 409C for 3 hours and then at 1059C for 5 hours, not exceeding 2 mm in sample layer)."
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Weigh accurately about 6 g of Dibasic Sodium Phos-phate Hydrate, dissolve in 50 mL of water, and then titrate <2.50> with 0.5 mol/L sulfuric acid VS at 159C until the green color of the solution changes to dark-greenish red-pur-ple (indicator: 3 to 4 drops of methyl orange-xylenecyanol FF TS). Each mL of 0.5 mol/L sulfuric acid VS ＝ 142.0 mg of Na HPO lated on the anhydrous basis, water, 100 mL). Purity (1) Clarity and color of solution—Dissolve 1.0 g of Sodium Picosulfate Hydrate in 10 mL of water: the solu-tion is clear and colorless to pale yellow. Chloride <1.03>—Perform the test with 0.5 g of So- dium Picosulfate Hydrate. Prepare the control solution with 0.40 mL of 0.01 mol/L hydrochloric acid VS (not more than 0.028z). Sulfate <1.14>—Perform the test with 0.40 g of So- dium Picosulfate Hydrate. Prepare the control solution with 0.35 mL of 0.005 mol/L sulfuric acid VS (not more than 2 4 0.042z)."
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Tight containers."
  }
}