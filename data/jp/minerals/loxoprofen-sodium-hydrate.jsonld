  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/minerals/loxoprofen-sodium-hydrate",
  "@type": "MineralSubstanceMonograph",
  "prefLabel": {
    "en": "Loxoprofen Sodium Hydrate",
    "ja": "ロキソプロフェンナトリウム水和物"
  },
  "monographId": "JP18-loxoprofen-sodium-hydrate",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "definition": {
    "en": "Loxoprofen Sodium Hydrate contains not less than 98."
  },
  "appearance": {
    "en": "Loxoprofen Sodium Hydrate occurs as white to yellowish white, crystals or crystalline powder. It is very soluble in water and in methanol, freely soluble in ethanol (95), and practically insoluble in diethyl ether. A solution of Loxoprofen Sodium Hydrate (1 in 20) does not show optical rotation. The pH of a solution of 1.0 g of Loxoprofen Sodium Hy-drate in 20 mL of freshly boiled and cooled water is between 6.5 and 8.5."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "(1) Determine the absorption spectrum of a solution of Loxoprofen Sodium Hydrate (1 in 55,000) as di-rected under Ultraviolet-visible Spectrophotometry <2.24>, and compare the spectrum with the Reference Spectrum: both spectra exhibit similar intensities of absorption at the same wavelengths. Determine the infrared absorption spectrum of Lox-oprofen Sodium Hydrate as directed in the potassium bro-mide disk method under the Infrared Spectrophotometry <2.25>, and compare the spectrum with the Reference Spec- trum: both spectra exhibit similar intensities of absorption at the same wave numbers. A solution of Loxoprofen Sodium Hydrate (1 in 10) responds to Qualitative Tests <1.09> for sodium salt."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Clarity and color of solution—Dissolve 1.0 g of Loxoprofen Sodium Hydrate in 10 mL of water: the solu-tion is clear and colorless or pale yellow. The color is not darker than that of diluted Matching Fluid A (1 in 2). Heavy metals <1.07>—Proceed with 2.0 g of Lox- oprofen Sodium Hydrate according to Method 2, and per-form the test. Prepare the control solution with 2.0 mL of Standard Lead Solution (not more than 10 ppm). Related substances—Dissolve 1.0 g of Loxoprofen Sodium Hydrate in 10 mL of methanol, and use this solution as the sample solution. Pipet 1 mL of the sample solution, add methanol to make exactly 200 mL, and use this solution ‌1280 as the standard solution. Perform the test with these solu-tions as directed under Thin-layer Chromatography <2.03>. Spot 10 mL each of the sample solution and standard solu-tion on a plate of silica gel with fluorescent indicator for thin-layer chromatography. Develop the plate with a mixture of 1,2-dichloroethane and acetic acid (100) (9:1) to a distance of about 15 cm, and air-dry the plate. Examine under ultra- Loxoprofen Sodium Tablets"
      }
    }
  ]
}