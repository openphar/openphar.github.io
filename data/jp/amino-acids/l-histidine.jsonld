{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/amino-acids/l-histidine",
  "@type": "AminoAcidMonograph",
  "prefLabel": {
    "en": "L-Histidine",
    "ja": "L-ヒスチジン"
  },
  "monographId": "JP18-l-histidine",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "molecularFormula": "C6H9N3O2",
  "molecularWeight": 155.15,
  "definition": {
    "en": "L-Histidine contains not less than 99."
  },
  "appearance": {
    "en": "L-Histidine occurs as white, crystals or crystal-line powder, having a slight bitter taste. It is freely soluble in formic acid, and soluble in water, and practically insoluble in ethanol (99.5). It dissolves in 6 mol/L hydrochloric acid TS. It shows crystal polymorphism."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "Determine the infrared absorption spectrum of L-Histidine as directed in the potassium bromide disk method under Infrared Spectrophotometry <2.25>, and com-pare the spectrum with the Reference Spectrum: both spectra exhibit similar intensities of absorption at the same wave numbers. If any difference appears between the spectra, dis-solve the sample with a little amount of water, evaporate the water at 609C under reduced pressure, dry the residue, and perform the test. D Optical rotation <2.49> [a]20: ＋11.8 – ＋12.89(5.5 g calcu-lated on the dried basis, 6 mol/L hydrochloric acid TS, 50 mL, 100 mm). pH <2.54> The pH of a solution of 1.0 g of L-Histidine in 50 mL of water is between 7.0 and 8.5."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Clarity and color of solution—A solution of 0.40 g of L-Histidine in 20 mL of water is clear and colorless. Chloride <1.03>—Perform the test with 0.5 g of L-Histidine. Prepare the control solution with 0.30 mL of 0.01 mol/L hydrochloric acid VS (not more than 0.021z). Sulfate <1.14>—Perform the test with 0.6 g of L-Histidine. Prepare the control solution with 0.35 mL of 0.005 mol/L sulfuric acid VS (not more than 0.028z). Ammonium <1.02>—Perform the test with 0.25 g of L-Histidine. Prepare the control solution with 5.0 mL of Standard Ammonium Solution (not more than 0.02z). Heavy metals <1.07>—Dissolve 1.0 g of L-Histidine in 30 mL of water by warming. To this solution add 2.4 mL of dilute hydrochloric acid, 2 mL of dilute acetic acid and water to make 50 mL. Perform the test using this solution as the test solution. Prepare the control solution as follows: To 1.0 mL of Standard Lead Solution add 2 mL of dilute acetic acid and water to make 50 mL (not more than 10 ppm). Iron <1.10>—Prepare the test solution with 1.0 g of L-Histidine according to Method 1, and perform the test ac-cording to Method A. Prepare the control solution with 1.0 mL of Standard Iron Solution (not more than 10 ppm). Related substances—Dissolve 0.10 g of L-Histidine in 10 mL of water, and use this solution as the sample solution. Pipet 1 mL of the sample solution, add water to make ex-actly 10 mL. Pipet 1 mL of this solution, add water to make exactly 50 mL, and use this solution as the standard solution. Perform the test with these solutions as directed under Thin-layer Chromatography <2.03>. Spot 5 mL each of the sample solution and standard solution on a plate of silica gel for thin-layer chromatography, develop the plate with a mixture of 1-propanol and ammonia solution (28) (67:33) to a dis-tance of about 10 cm, and dry the plate at 809C for 30 minutes. Spray evenly a solution of ninhydrin in a mixture of methanol and acetic acid (100) (97:3) (1 in 100) to the plate, and heat at 809C for 10 minutes: the spot other than the principal spot obtained from the sample solution is not more intense than the spot from the standard solution. Loss on drying <2.41> Not more than 0.3z (1 g, 1059C, 3 hours). Residue on ignition <2.44> Not more than 0.1z (1 g)."
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Weigh accurately about 0.15 g of L-Histidine, dis-solve in 2 mL of formic acid, add 50 mL of acetic acid (100), and titrate <2.50> with 0.1 mol/L perchloric acid VS (poten-tiometric titration). Perform a blank determination in the same manner, and make any necessary correction. Each mL of 0.1 mol/L perchloric acid VS ＝ 15.52 mg of C6H9N3O2"
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Tight containers."
  }
}