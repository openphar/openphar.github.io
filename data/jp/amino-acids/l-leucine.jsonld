{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/amino-acids/l-leucine",
  "@type": "AminoAcidMonograph",
  "prefLabel": {
    "en": "L-Leucine",
    "ja": "L-ロイシン"
  },
  "monographId": "JP18-l-leucine",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "molecularFormula": "C6H13NO2",
  "molecularWeight": 131.17,
  "definition": {
    "en": "L-Leucine, when dried, contains not less than 98."
  },
  "appearance": {
    "en": "L-Leucine occurs as white, crystals or crystal-line powder. It is odorless or has a faint characteristic odor, and has a slightly bitter taste. It is freely soluble in formic acid, sparingly soluble in water, and practically insoluble in ethanol (95). It dissolves in dilute hydrochloric acid."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "Determine the infrared absorption spectrum of L-Leucine, previously dried, as directed in the potassium bromide disk method under Infrared Spectrophotometry <2.25>, and compare the spectrum with the Reference Spec- trum: both spectra exhibit similar intensities of absorption at the same wave numbers. D Optical rotation <2.49> [a]20: ＋14.5 – ＋16.09(after dry-ing, 1 g, 6 mol/L hydrochloric acid TS, 25 mL, 100 mm). pH <2.54> Dissolve 1.0 g of L-Leucine in 100 mL of water: Pipet 5 mL of this solution, add water to make exactly 20 mL, and use this solution as the standard solution. Perform the test with these solutions as directed under Thin-layer Chromatography <2.03>. Spot 5 mL each of the sample solu-tion and standard solution on a plate of silica gel for thin-layer chromatography. Develop the plate with a mixture of 1-butanol, water and acetic acid (100) (3:1:1) to a distance of about 10 cm, and dry the plate at 809C for 30 minutes. Spray evenly a solution of ninhydrin in acetone (1 in 50) on the plate, and heat the plate at 809C for 5 minutes: the spots other than the principal spot obtained from the sample solu-tion are not more intense than the spot from the standard so-lution. Loss on drying <2.41> Not more than 0.30z (1 g, 1059C, 3 hours). Residue on ignition <2.44> Not more than 0.1z (1 g)."
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Weigh accurately about 0.13 g of L-Leucine, previ-ously dried, and dissolve in 3 mL of formic acid, add 50 mL of acetic acid (100), and titrate <2.50> with 0.1 mol/L per-chloric acid VS (potentiometric titration). Perform a blank determination in the same manner, and make any necessary correction. Each mL of 0.1 mol/L perchloric acid VS ＝ 13.12 mg of C6H13NO2"
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Well-closed contain-ers."
  }
}