{
  "@context": "https://www.openphar.org/ontology/context/pharmacopoeia.jsonld",
  "@id": "https://www.openphar.org/data/jp/amino-acids/l-valine",
  "@type": "AminoAcidMonograph",
  "prefLabel": {
    "en": "L-Valine",
    "ja": "L-バリン"
  },
  "monographId": "JP18-l-valine",
  "publisher": "JP",
  "status": "Official",
  "version": "18",
  "molecularFormula": "C5H11NO2",
  "molecularWeight": 117.15,
  "definition": {
    "en": "L-Valine, when dried, contains not less than 98."
  },
  "appearance": {
    "en": "L-Valine occurs as white, crystals or crystalline powder. It is odorless or has a faint characteristic odor, and has a slightly sweet taste, which becomes bitter. It is freely soluble in formic acid, soluble in water, and practically insoluble in ethanol (95). It dissolves in dilute hydrochloric acid."
  },
  "testSpecification": [
    {
      "@type": "IdentificationSpecification",
      "testName": {
        "en": "Identification"
      },
      "testType": "TestType-Identification",
      "testConditions": {
        "en": "Determine the infrared absorption spectrum of L-Valine, previously dried, as directed in the potassium bromide disk method under Infrared Spectrophotometry <2.25>, and compare the spectrum with the Reference Spec- trum: both spectra exhibit similar intensities of absorption at the same wave numbers. D Optical rotation <2.49> [a]20: ＋26.5 – ＋29.09(after dry-ing, 2 g, 6 mol/L hydrochloric acid TS, 25 mL, 100 mm). pH <2.54> Dissolve 0.5 g of L-Valine in 20 mL of water: the pH of this solution is between 5.5 and 6.5."
      }
    },
    {
      "@type": "PuritySpecification",
      "testName": {
        "en": "Purity"
      },
      "testType": "TestType-Purity",
      "testConditions": {
        "en": "(1) Clarity and color of solution—Dissolve 0.5 g of L-Valine in 20 mL of water: the solution is clear and col-orless. Chloride <1.03>—Perform the test with 0.5 g of L-Valine. Prepare the control solution with 0.30 mL of 0.01 mol/L hydrochloric acid VS (not more than 0.021z). Sulfate <1.14>—Perform the test with 0.6 g of L-Valine. Prepare the control solution with 0.35 mL of 0.005 mol/L sulfuric acid VS (not more than 0.028z). Ammonium <1.02>—Perform the test with 0.25 g of L-Valine. Prepare the control solution with 5.0 mL of Stand-ard Ammonium Solution (not more than 0.02z). Heavy metals <1.07>—Proceed with 1.0 g of L-Valine according to Method 1, and perform the test. Prepare the control solution with 2.0 mL of Standard Lead Solution (not more than 20 ppm). Arsenic <1.11>—Proceed with 1.0 g of L-Valine, pre-pare the test solution according to Method 2, and perform the test (not more than 2 ppm). Related substances—Dissolve 0.10 g of L-Valine in 25 mL of water, and use this solution as the sample solution. Pipet 1 mL of the sample solution, and add water to make exactly 50 mL. Pipet 5 mL of this solution, add water to make exactly 20 mL, and use this solution as the standard solution. Perform the test with these solutions as directed under Thin-layer Chromatography <2.03>. Spot 5 mL each of the sample solution and standard solution on a plate of silica gel for thin-layer chromatography. Develop the plate with a mixture of 1-butanol, water and acetic acid (100) (3:1:1) to a distance of about 10 cm, and dry the plate at 809C for 30 minutes. Spray evenly a solution of ninhydrin in acetone (1 in 50) on the plate, and heat the plate at 809C for 5 minutes: the spots other than the principal spot obtained from the ‌sample solution are not more intense than the spot from the standard solution. Loss on drying <2.41> Not more than 0.30z (1 g, 1059C, 3 hours). Residue on ignition <2.44> Not more than 0.1z (1 g)."
      }
    },
    {
      "@type": "AssaySpecification",
      "testName": {
        "en": "Assay"
      },
      "testType": "TestType-Assay",
      "testConditions": {
        "en": "Weigh accurately about 0.12 g of L-Valine, previ-ously dried, and dissolve in 3 mL of formic acid, add 50 mL of acetic acid (100), and titrate <2.50> with 0.1 mol/L per-chloric acid VS (potentiometric titration). Perform a blank determination in the same manner, and make any necessary correction. Each mL of 0.1 mol/L perchloric acid VS ＝ 11.72 mg of C5H11NO2"
      }
    }
  ],
  "storageConditions": {
    "en": "Containers—Tight containers."
  }
}